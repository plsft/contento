{
  "name": "contento",
  "version": "0.1.0",
  "description": "Local CLI for safe programmatic SEO. Bundles 150+ niches and 10 content schemas; works with any AI provider via your own API key.",
  "type": "module",
  "bin": {
    "contento": "./dist/bin/contento.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "contento",
    "pseo",
    "seo",
    "cli",
    "programmatic-seo",
    "ai",
    "static-site"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "eventsource": "^3.0.6",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^4.1.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
