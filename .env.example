# Contento CMS — Environment Configuration
# Copy this file to .env and fill in values for your environment.

# PostgreSQL connection string
DATABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=contento;Username=contento;Password=contento_secret

# Redis connection (optional — caching degrades gracefully if unavailable)
REDIS_CONNECTION_STRING=localhost:6379

# SMTP Email (optional — notifications disabled if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Force database migrations in production (default: false)
FORCE_MIGRATIONS=false
