@* Pagination partial — expects ViewData["CurrentPage"], ["TotalPages"], ["PaginationUrl"] (with {0} placeholder for page number) *@
@{
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var paginationUrl = (string)(ViewData["PaginationUrl"] ?? "?page={0}");
}

@if (totalPages > 1)
{
    <nav class="flex items-center justify-center gap-2 mt-12" aria-label="Pagination">
        @if (currentPage > 1)
        {
            <a href="@string.Format(paginationUrl, currentPage - 1)" class="px-3 py-2 rounded text-sm"
               style="color: var(--color-stone); border: 1px solid var(--color-mist);">
                &larr; Prev
            </a>
        }
        @for (var i = 1; i <= totalPages; i++)
        {
            if (i == currentPage)
            {
                <span class="px-3 py-2 rounded text-sm font-medium text-white" style="background: var(--color-indigo);">@i</span>
            }
            else if (i == 1 || i == totalPages || Math.Abs(i - currentPage) <= 2)
            {
                <a href="@string.Format(paginationUrl, i)" class="px-3 py-2 rounded text-sm"
                   style="color: var(--color-stone); border: 1px solid var(--color-mist);">@i</a>
            }
            else if (i == 2 || i == totalPages - 1)
            {
                <span class="px-2 text-sm" style="color: var(--color-ash);">&hellip;</span>
            }
        }
        @if (currentPage < totalPages)
        {
            <a href="@string.Format(paginationUrl, currentPage + 1)" class="px-3 py-2 rounded text-sm"
               style="color: var(--color-stone); border: 1px solid var(--color-mist);">
                Next &rarr;
            </a>
        }
    </nav>
}
