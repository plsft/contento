            <div class="flex items-center gap-3 px-2">
                <span style="color: var(--color-ash); font-size: 0.75rem;">Contento CMS</span>
                <p style="color: var(--color-cloud); font-size: 0.6875rem;" class="ml-auto">v1.0.0</p>
            </div>
        </div>
    </aside>

    <!-- Main content -->
    <div class="lg:pl-64 min-h-screen flex flex-col">
        <!-- Header -->
        <header class="sticky top-0 z-40 h-16 glass border-b" style="border-color: var(--color-mist);">
            <div class="flex h-full items-center gap-4 px-4 sm:px-6 lg:px-8">
                <!-- Mobile menu button -->
                <button @@click="sidebarOpen = true" class="lg:hidden -ml-2 p-2 rounded transition-colors" style="color: var(--color-ash);">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>

                <!-- Page title -->
                <div class="flex-1">
                    <h1 class="text-base font-medium" style="color: var(--color-ink);">@ViewData["Title"]</h1>
                </div>

                <!-- Right side -->
                <div class="flex items-center gap-3">
                    <!-- Dark mode toggle -->
                    <button @@click="$store.darkMode.toggle()" class="p-2 rounded transition-colors" style="color: var(--color-ash);" title="Toggle dark mode">
                        <template x-if="$store.darkMode.on">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                        </template>
                        <template x-if="!$store.darkMode.on">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                            </svg>
                        </template>
                    </button>
                    @{
                        var userName = User.FindFirst("display_name")?.Value ?? User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Writer";
                        var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "author";
                        var userInitial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "W";
                    }
                    <!-- User dropdown -->
                    <div class="relative" x-data="{ open: false }">
                        <button @@click="open = !open" class="flex items-center gap-3 p-1.5 rounded hover:bg-stone-100 transition-colors">
                            <div class="w-8 h-8 rounded flex items-center justify-center" style="background-color: var(--color-indigo-pale); color: var(--color-indigo);">
                                <span class="text-sm font-medium">@userInitial</span>
                            </div>
                            <div class="hidden sm:block text-left">
                                <p class="text-sm font-medium" style="color: var(--color-ink);">@userName</p>
                                <p class="text-xs" style="color: var(--color-ash);">@userRole</p>
                            </div>
                        </button>

                        <div x-show="open" x-cloak @@click.away="open = false"
                             x-transition:enter="transition ease-out duration-100"
                             x-transition:enter-start="opacity-0 scale-95"
                             x-transition:enter-end="opacity-100 scale-100"
                             x-transition:leave="transition ease-in duration-75"
                             x-transition:leave-start="opacity-100 scale-100"
                             x-transition:leave-end="opacity-0 scale-95"
                             class="absolute right-0 mt-2 w-48 origin-top-right border rounded-lg shadow-lg divide-y z-50" style="background: var(--color-snow); border-color: var(--color-mist);">
                            <div class="py-1">
                                <a href="/admin/settings" class="flex items-center gap-3 px-4 py-2 text-sm transition-colors" style="color: var(--color-stone);">
                                    Settings
                                </a>
                            </div>
                            <div class="py-1">
                                <a href="/oauth/logout" class="flex items-center gap-3 px-4 py-2 text-sm transition-colors" style="color: var(--color-danger);">
                                    Sign out
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 py-8 px-4 sm:px-6 lg:px-8">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="border-t py-6 px-4 sm:px-6 lg:px-8" style="border-color: var(--color-mist); background: var(--color-snow);">
            <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                <p class="text-sm" style="color: var(--color-ash);">
                    &copy; @DateTime.Now.Year Contento
                </p>
            </div>
        </footer>
    </div>
</div>

<!-- Toast notifications -->
<div x-data class="fixed bottom-4 right-4 z-50 flex flex-col gap-2">
    <template x-for="toast in $store.toast.items" :key="toast.id">
        <div x-show="true"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 translate-y-2"
             x-transition:enter-end="opacity-100 translate-y-0"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             class="px-4 py-3 rounded-lg shadow-lg text-sm font-medium"
             :class="{
                 'bg-green-50 text-green-800 border border-green-200': toast.type === 'success',
                 'bg-red-50 text-red-800 border border-red-200': toast.type === 'error',
                 'bg-blue-50 text-blue-800 border border-blue-200': toast.type === 'info',
                 'bg-yellow-50 text-yellow-800 border border-yellow-200': toast.type === 'warning'
             }"
             x-text="toast.message">
        </div>
    </template>
</div>

<!-- Alpine.js initialization -->
<script>
    document.addEventListener('alpine:init', () => {
        Alpine.store('darkMode', {
            on: localStorage.getItem('contento-dark') === 'true' ||
                (!localStorage.getItem('contento-dark') && window.matchMedia('(prefers-color-scheme: dark)').matches),
            toggle() {
                this.on = !this.on;
                localStorage.setItem('contento-dark', this.on);
            }
        });

        Alpine.store('loading', {
            active: false,
            message: 'Loading...',
            show(message = 'Loading...') {
                this.message = message;
                this.active = true;
            },
            hide() {
                this.active = false;
            }
        });

        Alpine.store('toast', {
            items: [],
            show(message, type = 'info', duration = 4000) {
                const id = Date.now();
                this.items.push({ id, message, type });
                setTimeout(() => {
                    this.items = this.items.filter(t => t.id !== id);
                }, duration);
            }
        });
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
