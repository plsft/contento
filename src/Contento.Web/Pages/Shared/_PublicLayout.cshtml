@inject Contento.Core.Interfaces.IThemeService ThemeService
@inject Contento.Core.Interfaces.ILayoutService LayoutService
@inject Contento.Core.Interfaces.ISiteService SiteService
@inject Contento.Core.Interfaces.ILayoutRenderer LayoutRenderer
@inject Contento.Core.Interfaces.IMenuService MenuService
@inject Microsoft.Extensions.Logging.ILoggerFactory LoggerFactory
@{
    var Logger = LoggerFactory.CreateLogger("Contento.PublicLayout");
    var siteTitle = ViewData["SiteTitle"]?.ToString() ?? "Contento";
    var siteTagline = ViewData["SiteTagline"]?.ToString() ?? "";

    // Load active theme CSS variables
    var themeStyleBlock = "";
    try
    {
        var activeTheme = await ThemeService.GetActiveAsync();
        if (activeTheme?.CssVariables is not null)
        {
            var vars = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(activeTheme.CssVariables);
            if (vars is { Count: > 0 })
            {
                // Use html:root selector (specificity 0,1,1) to override
                // the .dark and @media(prefers-color-scheme:dark) html:not(.light)
                // rules in app.css which also have specificity 0,1,1 but appear
                // earlier in source order, so this <style> tag wins.
                var sb = new System.Text.StringBuilder("html:root{");
                foreach (var kv in vars)
                {
                    sb.Append($"{kv.Key}:{kv.Value};");
                }
                sb.Append('}');
                themeStyleBlock = sb.ToString();
            }
        }
    }
    catch (Exception ex) { Logger.LogError(ex, "Failed to load theme in {Layout}", "_PublicLayout"); }

    // Load layout render context
    var layoutMaxWidth = "56rem";
    var layoutCustomCss = "";
    var layoutCustomJs = "";
    var layoutHeadContent = "";
    Contento.Core.Interfaces.LayoutRenderContext? layoutContext = null;
    var useGrid = false;

    try
    {
        var site = Contento.Web.Middleware.HttpContextExtensions.TryGetCurrentSite(Context);
        if (site is not null)
        {
            // Build layout render context (loads components + structure)
            var postLayoutId = ViewData["PostLayoutId"] as Guid?;
            layoutContext = await LayoutRenderer.BuildRenderContextAsync(site.Id, postLayoutId);
            useGrid = layoutContext?.HasLayout == true
                      && layoutContext.RegionContent.Count > 0;

            var layout = await LayoutService.GetDefaultAsync(site.Id);
            if (layout is not null)
            {
                // Extract maxWidth from Structure JSON
                if (!string.IsNullOrEmpty(layout.Structure))
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(layout.Structure);
                    if (doc.RootElement.TryGetProperty("defaults", out var defaults)
                        && defaults.TryGetProperty("maxWidth", out var mw))
                    {
                        layoutMaxWidth = mw.GetString() ?? layoutMaxWidth;
                    }
                }
                layoutCustomCss = layout.CustomCss ?? "";
                layoutCustomJs = layout.CustomJs ?? "";
                layoutHeadContent = layout.HeadContent ?? "";

                if (layoutContext != null)
                    layoutMaxWidth = layoutContext.MaxWidth ?? layoutMaxWidth;
            }
        }
    }
    catch (Exception ex) { Logger.LogError(ex, "Failed to load layout in {Layout}", "_PublicLayout"); }

    // Plugin hooks: site:head
    var pluginHeadHtml = "";
    var pluginFooterHtml = "";
    try
    {
        var pluginRuntime = ViewContext.HttpContext.RequestServices.GetService<Contento.Core.Interfaces.IPluginRuntime>();
        if (pluginRuntime != null)
        {
            var siteContext = System.Text.Json.JsonSerializer.Serialize(new { site = new { title = siteTitle } });
            var headResults = pluginRuntime.BroadcastHook("site:head", siteContext);
            pluginHeadHtml = string.Join("\n", headResults.Values.Where(v => v != null));

            var footerResults = pluginRuntime.BroadcastHook("site:footer", siteContext);
            pluginFooterHtml = string.Join("\n", footerResults.Values.Where(v => v != null));
        }
    }
    catch (Exception ex) { Logger.LogError(ex, "Failed to invoke plugin hooks in {Layout}", "_PublicLayout"); }

    // Load navigation menus
    var headerMenuItems = new List<Contento.Core.Interfaces.MenuItemNode>();
    var footerMenuItems = new List<Contento.Core.Interfaces.MenuItemNode>();
    try
    {
        var menuSite = Contento.Web.Middleware.HttpContextExtensions.TryGetCurrentSite(Context);
        if (menuSite is not null)
        {
            var headerMenu = await MenuService.GetByLocationAsync(menuSite.Id, "header");
            if (headerMenu is not null)
                headerMenuItems = (await MenuService.GetItemTreeAsync(headerMenu.Id)).ToList();

            var footerMenu = await MenuService.GetByLocationAsync(menuSite.Id, "footer");
            if (footerMenu is not null)
                footerMenuItems = (await MenuService.GetItemTreeAsync(footerMenu.Id)).ToList();
        }
    }
    catch (Exception ex) { Logger.LogError(ex, "Failed to load menus in {Layout}", "_PublicLayout"); }
}
<!DOCTYPE html>
<html lang="en" :class="$store.darkMode.on ? 'dark' : 'light'">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @siteTitle</title>

    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }

    <!-- OpenGraph -->
    <meta property="og:title" content="@(ViewData["OgTitle"] ?? ViewData["Title"])" />
    <meta property="og:type" content="article" />
    @if (ViewData["OgImage"] != null)
    {
        <meta property="og:image" content="@ViewData["OgImage"]" />
    }
    @if (ViewData["CanonicalUrl"] != null)
    {
        <link rel="canonical" href="@ViewData["CanonicalUrl"]" />
        <meta property="og:url" content="@ViewData["CanonicalUrl"]" />
    }

    <!-- OpenGraph (extended) -->
    <meta property="og:description" content="@(ViewData["MetaDescription"] ?? siteTagline)" />
    <meta property="og:site_name" content="@siteTitle" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@(ViewData["OgTitle"] ?? ViewData["Title"])" />
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="twitter:description" content="@ViewData["MetaDescription"]" />
    }
    @if (ViewData["OgImage"] != null)
    {
        <meta name="twitter:image" content="@ViewData["OgImage"]" />
    }

    <!-- JSON-LD Structured Data -->
    @{
        var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
        var currentUrl = $"{baseUrl}{Context.Request.Path}";
        var isHomePage = Context.Request.Path == "/" || Context.Request.Path == "";
        var isPostPage = ViewData["PostId"] != null;

        string JsonLd(Dictionary<string, object?> data)
        {
            data["@context"] = "https://schema.org";
            return System.Text.Json.JsonSerializer.Serialize(data,
                new System.Text.Json.JsonSerializerOptions { DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull });
        }
    }
    @if (isHomePage)
    {
        <script type="application/ld+json">@Html.Raw(JsonLd(new Dictionary<string, object?> {
            ["@type"] = "WebSite", ["name"] = siteTitle, ["description"] = siteTagline, ["url"] = baseUrl
        }))</script>
        <script type="application/ld+json">@Html.Raw(JsonLd(new Dictionary<string, object?> {
            ["@type"] = "Organization", ["name"] = siteTitle, ["url"] = baseUrl
        }))</script>
    }
    @if (isPostPage)
    {
        <script type="application/ld+json">@Html.Raw(JsonLd(new Dictionary<string, object?> {
            ["@type"] = "Article",
            ["headline"] = ViewData["Title"]?.ToString(),
            ["description"] = ViewData["MetaDescription"]?.ToString(),
            ["image"] = ViewData["OgImage"]?.ToString(),
            ["url"] = ViewData["CanonicalUrl"]?.ToString() ?? currentUrl,
            ["datePublished"] = ViewData["DatePublished"]?.ToString(),
            ["dateModified"] = ViewData["DateModified"]?.ToString(),
            ["author"] = new Dictionary<string, object?> { ["@type"] = "Person", ["name"] = ViewData["AuthorName"]?.ToString() ?? siteTitle },
            ["publisher"] = new Dictionary<string, object?> { ["@type"] = "Organization", ["name"] = siteTitle }
        }))</script>
    }
    <script type="application/ld+json">@Html.Raw(JsonLd(new Dictionary<string, object?> {
        ["@type"] = "BreadcrumbList",
        ["itemListElement"] = new[] {
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "Home", ["item"] = baseUrl + "/" },
            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = ViewData["Title"]?.ToString() ?? "Page", ["item"] = currentUrl }
        }
    }))</script>

    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="alternate" type="application/rss+xml" title="@siteTitle RSS Feed" href="/feed.xml" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3/dist/cdn.min.js"></script>

    @await RenderSectionAsync("Head", required: false)

    @if (!string.IsNullOrEmpty(themeStyleBlock))
    {
        <style>@Html.Raw(themeStyleBlock)</style>
    }
    <style>
        body {
            font-family: var(--font-serif);
            color: var(--color-ink);
            background: var(--color-paper);
        }
    </style>
    @if (!string.IsNullOrEmpty(layoutCustomCss))
    {
        <style>@Html.Raw(layoutCustomCss)</style>
    }
    @if (!string.IsNullOrEmpty(layoutHeadContent))
    {
        @Html.Raw(layoutHeadContent)
    }
    @if (!string.IsNullOrEmpty(pluginHeadHtml))
    {
        @Html.Raw(pluginHeadHtml)
    }
</head>
<body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="border-b py-6" style="border-color: var(--color-mist);">
        <div class="mx-auto px-4 sm:px-6" style="max-width: @layoutMaxWidth;">
            <div class="flex items-center justify-between">
                <a href="/" class="text-xl font-semibold" style="color: var(--color-ink); font-family: var(--font-serif); letter-spacing: -0.02em;">
                    @siteTitle
                </a>
                <nav class="flex items-center gap-6">
                    @if (headerMenuItems.Count > 0)
                    {
                        @foreach (var item in headerMenuItems)
                        {
                            if (item.Children.Count > 0)
                            {
                                <div x-data="{ open: false }" class="relative">
                                    <button @@click="open = !open" @@click.outside="open = false"
                                            class="text-sm flex items-center gap-1" style="color: var(--color-stone);">
                                        @item.Label
                                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                        </svg>
                                    </button>
                                    <div x-show="open" x-cloak x-transition
                                         class="absolute top-full left-0 mt-2 py-1 rounded shadow-lg border min-w-[160px] z-50"
                                         style="background: var(--color-paper); border-color: var(--color-mist);">
                                        @foreach (var child in item.Children)
                                        {
                                            <a href="@child.Url" target="@child.Target"
                                               class="block px-4 py-2 text-sm hover:opacity-80 @(child.CssClass)"
                                               style="color: var(--color-stone);">
                                                @child.Label
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <a href="@item.Url" target="@item.Target"
                                   class="text-sm @(item.CssClass)" style="color: var(--color-stone);">
                                    @item.Label
                                </a>
                            }
                        }
                    }
                    else
                    {
                        <a href="/" class="text-sm" style="color: var(--color-stone);">Home</a>
                    }
                    <!-- Dark mode toggle -->
                    <button @@click="$store.darkMode.toggle()" class="p-1.5 rounded" style="color: var(--color-ash);" title="Toggle dark mode">
                        <template x-if="$store.darkMode.on">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                            </svg>
                        </template>
                        <template x-if="!$store.darkMode.on">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                            </svg>
                        </template>
                    </button>
                </nav>
            </div>
            @if (!string.IsNullOrEmpty(siteTagline))
            {
                <p class="mt-1 text-sm" style="color: var(--color-ash);">@siteTagline</p>
            }
        </div>
    </header>

    <!-- Main content -->
    <main class="flex-1 py-8">
        @if (useGrid && layoutContext != null)
        {
            // Grid layout: body + sidebar regions
            var gap = layoutContext.Gap ?? "1.5rem";
            <div style="display: grid; grid-template-columns: repeat(12, 1fr); gap: @gap; max-width: @layoutMaxWidth;" class="mx-auto px-4 sm:px-6">
                @{
                    // Parse structure for body column span
                    var bodySpan = 12;
                    try
                    {
                        using var doc = System.Text.Json.JsonDocument.Parse(layoutContext.StructureJson ?? "{}");
                        if (doc.RootElement.TryGetProperty("rows", out var rowsEl))
                        {
                            foreach (var row in rowsEl.EnumerateArray())
                            {
                                if (row.TryGetProperty("regions", out var regionsEl))
                                {
                                    foreach (var region in regionsEl.EnumerateArray())
                                    {
                                        var name = region.GetProperty("region").GetString();
                                        if (name == "body" && region.TryGetProperty("cols", out var c))
                                            bodySpan = c.GetInt32();
                                    }
                                }
                            }
                        }
                    }
                    catch { }
                }
                <div style="grid-column: span @bodySpan / span @bodySpan;">
                    @RenderBody()
                </div>
                @{ ViewData["LayoutContext"] = layoutContext; }
                <partial name="_LayoutGrid" />
            </div>
        }
        else
        {
            <div class="mx-auto px-4 sm:px-6" style="max-width: @layoutMaxWidth;">
                @RenderBody()
            </div>
        }
    </main>

    <!-- Newsletter signup -->
    <section class="border-t py-10" style="border-color: var(--color-mist); background: var(--color-cloud);"
             x-data="{ email: '', status: '', loading: false }">
        <div class="mx-auto px-4 sm:px-6 text-center" style="max-width: @layoutMaxWidth;">
            <h3 class="text-lg font-semibold mb-2" style="color: var(--color-ink);">Subscribe to our newsletter</h3>
            <p class="text-sm mb-4" style="color: var(--color-stone);">Get the latest posts delivered to your inbox.</p>
            <form @@submit.prevent="
                loading = true; status = '';
                fetch('/api/v1/newsletter/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email })
                })
                .then(r => r.json())
                .then(d => { status = d.error ? 'error' : 'success'; email = ''; })
                .catch(() => { status = 'error'; })
                .finally(() => { loading = false; })
            " class="flex gap-2 justify-center max-w-md mx-auto">
                <input type="email" x-model="email" required placeholder="your@email.com"
                       class="flex-1 px-3 py-2 rounded border text-sm"
                       style="border-color: var(--color-mist); background: var(--color-paper); color: var(--color-ink);" />
                <button type="submit" :disabled="loading"
                        class="px-4 py-2 rounded text-sm font-medium text-white"
                        style="background: var(--color-indigo);">
                    Subscribe
                </button>
            </form>
            <p x-show="status === 'success'" class="text-sm mt-2" style="color: var(--color-indigo);">Thanks for subscribing!</p>
            <p x-show="status === 'error'" class="text-sm mt-2" style="color: #dc2626;">Something went wrong. Please try again.</p>
        </div>
    </section>

    <!-- Footer -->
    <footer class="border-t py-8" style="border-color: var(--color-mist);">
        <div class="mx-auto px-4 sm:px-6 text-center" style="max-width: @layoutMaxWidth;">
            @if (footerMenuItems.Count > 0)
            {
                <nav class="flex items-center justify-center gap-4 mb-3">
                    @foreach (var item in footerMenuItems)
                    {
                        <a href="@item.Url" target="@item.Target"
                           class="text-sm @(item.CssClass)" style="color: var(--color-ash);">
                            @item.Label
                        </a>
                    }
                </nav>
            }
            <p class="text-sm" style="color: var(--color-ash);">
                &copy; @DateTime.Now.Year @siteTitle · Powered by <a href="#" style="color: var(--color-indigo);">Contento</a>
            </p>
        </div>
    </footer>

    @if (!string.IsNullOrEmpty(pluginFooterHtml))
    {
        @Html.Raw(pluginFooterHtml)
    }

    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.store('darkMode', {
                on: localStorage.getItem('contento-dark') === 'true' ||
                    (!localStorage.getItem('contento-dark') && window.matchMedia('(prefers-color-scheme: dark)').matches),
                toggle() {
                    this.on = !this.on;
                    localStorage.setItem('contento-dark', this.on);
                }
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    @if (!string.IsNullOrEmpty(layoutCustomJs))
    {
        <script>@Html.Raw(layoutCustomJs)</script>
    }
</body>
</html>
