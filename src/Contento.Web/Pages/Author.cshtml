@page "/author/{slug}"
@model Contento.Web.Pages.AuthorModel
@{
    ViewData["Title"] = Model.AuthorUser?.DisplayName ?? "Author";
    Layout = "_PublicLayout";
    ViewData["SiteTitle"] = Model.SiteName;
    ViewData["SiteTagline"] = Model.SiteTagline;
}

<div>
    <div class="flex items-start gap-6 mb-10">
        @if (!string.IsNullOrEmpty(Model.AuthorUser?.AvatarUrl))
        {
            <img src="@Model.AuthorUser.AvatarUrl" alt="@Model.AuthorUser.DisplayName"
                 class="w-20 h-20 rounded-full object-cover shrink-0" loading="lazy" />
        }
        else
        {
            <div class="w-20 h-20 rounded-full flex items-center justify-center text-2xl font-semibold shrink-0"
                 style="background: var(--color-snow); color: var(--color-stone);">
                @(Model.AuthorUser?.DisplayName?.FirstOrDefault().ToString().ToUpperInvariant() ?? "?")
            </div>
        }
        <div>
            <h1 class="text-3xl font-semibold mb-2" style="font-family: var(--font-serif); color: var(--color-ink);">
                @Model.AuthorUser?.DisplayName
            </h1>
            @if (!string.IsNullOrEmpty(Model.AuthorUser?.Bio))
            {
                <p class="text-base mb-3" style="color: var(--color-stone); line-height: 1.7;">@Model.AuthorUser.Bio</p>
            }
            <p class="text-sm" style="color: var(--color-ash);">
                @Model.TotalCount post@(Model.TotalCount != 1 ? "s" : "") published
            </p>
        </div>
    </div>

    <div class="space-y-10">
        @foreach (var post in Model.Posts)
        {
            <article class="group">
                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                {
                    <a href="/@post.Slug">
                        <img src="@post.CoverImageUrl" alt="@post.Title"
                             class="w-full h-48 object-cover rounded-lg mb-4" loading="lazy" />
                    </a>
                }
                <h2 class="text-2xl font-semibold mb-2" style="font-family: var(--font-serif);">
                    <a href="/@post.Slug" class="hover:underline" style="color: var(--color-ink);">@post.Title</a>
                </h2>
                @if (!string.IsNullOrEmpty(post.Excerpt))
                {
                    <p class="text-base mb-3" style="color: var(--color-stone); line-height: 1.7;">@post.Excerpt</p>
                }
                <div class="flex items-center gap-4 text-sm" style="color: var(--color-ash);">
                    <time datetime="@post.PublishedAt?.ToString("yyyy-MM-dd")">
                        @post.PublishedAt?.ToString("MMMM d, yyyy")
                    </time>
                    <span>&middot;</span>
                    <span>@(post.ReadingTimeMinutes ?? 1) min read</span>
                </div>
            </article>
        }

        @if (!Model.Posts.Any())
        {
            <div class="text-center py-20">
                <p class="text-lg" style="color: var(--color-cloud);">No posts by this author yet.</p>
            </div>
        }
    </div>

    @{
        ViewData["CurrentPage"] = Model.CurrentPage;
        ViewData["TotalPages"] = Model.TotalPages;
        ViewData["PaginationUrl"] = "?page={0}";
    }
    <partial name="_Pagination" />
</div>
