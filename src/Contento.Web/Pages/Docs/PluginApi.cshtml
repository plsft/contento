    <!-- ================================================================== -->
    <!-- 1. Global API                                                      -->
    <!-- ================================================================== -->
    <section id="global-api">
        <h2>1. Global API</h2>
        <p>
            The <code>contento</code> global object is the primary interface for plugin code.
            It provides methods to register callbacks for lifecycle hooks.
        </p>

        <!-- contento.on() -->
        <div style="margin-bottom: 2rem;">
            <div class="method-sig">
                <span class="method-name">contento.on</span><span class="method-params">(hookName, callback)</span>
            </div>
            <p>
                Registers a callback function for a named hook. The callback receives a context
                object whose shape depends on the hook being invoked.
            </p>

            <h3>Parameters</h3>
            <ul class="param-list">
                <li><code>hookName</code> <span style="color: var(--color-ash);">(string)</span> &mdash; The hook to listen for. Must match one of the supported hook names listed in the <a href="#hooks-reference" style="color: var(--color-indigo);">Hooks Reference</a>.</li>
                <li><code>callback</code> <span style="color: var(--color-ash);">(function)</span> &mdash; Handler function that receives a context object. The shape of the context depends on the hook.</li>
            </ul>

            <h3>Returns</h3>
            <p><code>void</code></p>

            <h3>Example</h3>
<pre><code>contento.on('post:render', function (context) {
    var headings = context.document.querySelectorAll('h2, h3');
    // Build a table of contents from headings
});</code></pre>

            <div class="note-box">
                A plugin can register multiple callbacks for the same hook. They execute in registration order.
                A plugin can also register callbacks for multiple different hooks.
            </div>
        </div>
    </section>

    <!-- ================================================================== -->
    <!-- 2. Hooks Reference                                                 -->
    <!-- ================================================================== -->
    <section id="hooks-reference" class="api-section">
        <h2>2. Hooks Reference</h2>
        <p>
            Hooks are named events fired at specific points during page rendering and content
            lifecycle. Register a callback with <code>contento.on(hookName, callback)</code>
            to respond to these events.
        </p>

        <!-- post:render -->
        <div class="hook-card">
            <h4>post:render</h4>
            <div class="hook-meta">
                <p><strong>Fired:</strong> When a post is rendered for display on the public site.</p>
                <p><strong>Context:</strong> <code>{ post, document, site }</code></p>
                <p><strong>Use cases:</strong> Add a table of contents, inject social share buttons, modify HTML output, add analytics scripts, insert reading progress bars.</p>
                <p style="margin-bottom: 0;"><strong>Note:</strong> This is the most commonly used hook. It provides full DOM access via the <code>document</code> object, allowing you to query and manipulate the rendered HTML before it is sent to the browser.</p>
            </div>
        </div>

<pre><code>contento.on('post:render', function (context) {
    // Add a "Back to top" link after the post body
    var link = context.document.createElement('a');
    link.setAttribute('href', '#');
    link.textContent = 'Back to top';
    link.className = 'back-to-top';
    context.document.body.appendChild(link);
});</code></pre>

        <!-- post:beforeSave -->
        <div class="hook-card">
            <h4>post:beforeSave</h4>
            <div class="hook-meta">
                <p><strong>Fired:</strong> Before a post is persisted to the database.</p>
                <p><strong>Context:</strong> <code>{ post, content }</code></p>
                <p><strong>Use cases:</strong> Content transformation, auto-tagging, word count validation, profanity filtering, slug generation.</p>
                <p style="margin-bottom: 0;"><strong>Note:</strong> Modifications to <code>content</code> in this hook are saved to the database. The <code>document</code> object is not available in this hook.</p>
            </div>
        </div>

<pre><code>contento.on('post:beforeSave', function (context) {
    // Auto-generate excerpt from content if not provided
    if (!context.post.excerpt && context.content) {
        var plain = context.content.replace(/&lt;[^&gt;]*&gt;/g, '');
        context.post.excerpt = plain.substring(0, 160) + '...';
    }
});</code></pre>

        <!-- site:head -->
        <div class="hook-card">
            <h4>site:head</h4>
            <div class="hook-meta">
                <p><strong>Fired:</strong> When building the <code>&lt;head&gt;</code> section of any page.</p>
                <p><strong>Context:</strong> <code>{ site, page }</code></p>
                <p><strong>Return:</strong> HTML string to inject into <code>&lt;head&gt;</code>.</p>
                <p><strong>Use cases:</strong> Custom meta tags, external stylesheets, font loading, preconnect hints, structured data (JSON-LD).</p>
                <p style="margin-bottom: 0;"><strong>Note:</strong> The return value is inserted as raw HTML. Ensure it is well-formed.</p>
            </div>
        </div>

<pre><code>contento.on('site:head', function (context) {
    return '&lt;link rel="preconnect" href="https://fonts.googleapis.com"&gt;' +
           '&lt;link href="https://fonts.googleapis.com/css2?family=Inter&amp;display=swap" rel="stylesheet"&gt;';
});</code></pre>

        <!-- site:footer -->
        <div class="hook-card">
            <h4>site:footer</h4>
            <div class="hook-meta">
                <p><strong>Fired:</strong> Before <code>&lt;/body&gt;</code> on any page.</p>
                <p><strong>Context:</strong> <code>{ site, page }</code></p>
                <p><strong>Return:</strong> HTML string to inject before <code>&lt;/body&gt;</code>.</p>
                <p><strong>Use cases:</strong> Analytics scripts, chat widgets, notification bars, cookie consent banners.</p>
                <p style="margin-bottom: 0;"><strong>Note:</strong> Scripts injected here execute after the page content has loaded.</p>
            </div>
        </div>

<pre><code>contento.on('site:footer', function (context) {
    var trackingId = PLUGIN_SETTINGS.trackingId || '';
    if (!trackingId) return '';

    return '&lt;script&gt;' +
           '(function() { /* analytics snippet */ })();' +
           '&lt;/script&gt;';
});</code></pre>

        <!-- Hook summary table -->
        <h3 style="margin-top: 2rem;">Hook Summary</h3>
        <table>
            <thead>
                <tr>
                    <th>Hook</th>
                    <th>Context Properties</th>
                    <th>Returns</th>
                    <th>DOM Access</th>
                </tr>
