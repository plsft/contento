@page "/page/{slug}"
@model Contento.Web.Pages.ContentPageModel
@{
    ViewData["Title"] = Model.PagePost?.MetaTitle ?? Model.PagePost?.Title ?? "Page";
    Layout = "_PublicLayout";
    ViewData["SiteTitle"] = Model.SiteName;
    ViewData["SiteTagline"] = Model.SiteTagline;
    ViewData["MetaDescription"] = Model.PagePost?.MetaDescription ?? Model.PagePost?.Excerpt;
    ViewData["OgTitle"] = Model.PagePost?.MetaTitle ?? Model.PagePost?.Title;
    ViewData["OgImage"] = Model.PagePost?.OgImageUrl ?? Model.PagePost?.CoverImageUrl;
    ViewData["CanonicalUrl"] = Model.PagePost?.CanonicalUrl;
}

<article class="max-w-none">
    @if (!string.IsNullOrEmpty(Model.PagePost?.CoverImageUrl))
    {
        <img src="@Model.PagePost.CoverImageUrl" alt="@Model.PagePost.Title"
             class="w-full h-72 object-cover rounded-lg mb-8" loading="lazy" />
    }

    <h1 class="text-4xl font-bold mb-2" style="font-family: var(--font-serif); color: var(--color-ink); line-height: 1.2;">
        @Model.PagePost?.Title
    </h1>

    @if (!string.IsNullOrEmpty(Model.PagePost?.Subtitle))
    {
        <p class="text-xl mb-8" style="color: var(--color-stone);">@Model.PagePost.Subtitle</p>
    }
    else
    {
        <div class="mb-8"></div>
    }

    <div class="editor-content prose prose-lg" style="color: var(--color-ink); line-height: 1.8;">
        @Html.Raw(Model.PagePost?.BodyHtml)
    </div>
</article>
