@page "/tag/{tag}"
@model Contento.Web.Pages.TagModel
@{
    ViewData["Title"] = $"Tag: {Model.TagName}";
    Layout = "_PublicLayout";
    ViewData["SiteTitle"] = Model.SiteName;
    ViewData["SiteTagline"] = Model.SiteTagline;
}

<div>
    <h1 class="text-3xl font-semibold mb-2" style="font-family: var(--font-serif); color: var(--color-ink);">
        #@Model.TagName
    </h1>
    <p class="text-sm mb-10" style="color: var(--color-ash);">
        @Model.TotalCount post@(Model.TotalCount != 1 ? "s" : "") tagged with "@Model.TagName"
    </p>

    <div class="space-y-10">
        @foreach (var post in Model.Posts)
        {
            <article class="group">
                @if (!string.IsNullOrEmpty(post.CoverImageUrl))
                {
                    <a href="/@post.Slug">
                        <img src="@post.CoverImageUrl" alt="@post.Title"
                             class="w-full h-48 object-cover rounded-lg mb-4" loading="lazy" />
                    </a>
                }
                <h2 class="text-2xl font-semibold mb-2" style="font-family: var(--font-serif);">
                    <a href="/@post.Slug" class="hover:underline" style="color: var(--color-ink);">@post.Title</a>
                </h2>
                @if (!string.IsNullOrEmpty(post.Excerpt))
                {
                    <p class="text-base mb-3" style="color: var(--color-stone); line-height: 1.7;">@post.Excerpt</p>
                }
                <div class="flex items-center gap-4 text-sm" style="color: var(--color-ash);">
                    <time datetime="@post.PublishedAt?.ToString("yyyy-MM-dd")">
                        @post.PublishedAt?.ToString("MMMM d, yyyy")
                    </time>
                    <span>&middot;</span>
                    <span>@(post.ReadingTimeMinutes ?? 1) min read</span>
                </div>
            </article>
        }

        @if (!Model.Posts.Any())
        {
            <div class="text-center py-20">
                <p class="text-lg" style="color: var(--color-cloud);">No posts with this tag yet.</p>
            </div>
        }
    </div>

    @{
        ViewData["CurrentPage"] = Model.CurrentPage;
        ViewData["TotalPages"] = Model.TotalPages;
        ViewData["PaginationUrl"] = "?page={0}";
    }
    <partial name="_Pagination" />
</div>
