@page "/admin/sites"
@model Contento.Web.Pages.Admin.Sites.IndexModel
@{
    ViewData["Title"] = "Sites";
}

<div class="max-w-5xl mx-auto" x-data="{ showCreate: false }">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Sites</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">Manage your Contento site instances</p>
        </div>
        <button @@click="showCreate = !showCreate" class="btn btn-primary btn-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
            New Site
        </button>
    </div>

    <!-- Create Form -->
    <div x-show="showCreate" x-cloak x-transition class="card mb-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold" style="color: var(--color-ink);">New Site</h3>
            <button @@click="showCreate = false" class="p-1 rounded hover:bg-stone-100" style="color: var(--color-ash);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" asp-page-handler="Create">
            <div class="space-y-4">
                <div>
                    <label class="form-label">Name</label>
                    <input type="text" name="Name" class="form-input" placeholder="e.g. My Blog" required />
                </div>
                <div>
                    <label class="form-label">Slug</label>
                    <input type="text" name="SiteSlug" class="form-input" placeholder="e.g. my-blog" required />
                </div>
                <div>
                    <label class="form-label">Domain</label>
                    <input type="text" name="Domain" class="form-input" placeholder="e.g. myblog.com (optional)" />
                </div>
                <div class="flex items-center gap-3">
                    <button type="submit" class="btn btn-primary btn-sm">Create Site</button>
                    <button type="button" @@click="showCreate = false" class="btn btn-ghost btn-sm">Cancel</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Sites Table -->
    @if (Model.Sites.Any())
    {
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Domain</th>
                        <th>Primary</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var site in Model.Sites)
                    {
                        <tr>
                            <td>
                                <span class="font-medium" style="color: var(--color-ink);">@site.Name</span>
                            </td>
                            <td>
                                <span class="text-xs font-mono" style="color: var(--color-ash);">@site.Slug</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(site.Domain))
                                {
                                    <span class="text-sm" style="color: var(--color-stone);">@site.Domain</span>
                                }
                                else
                                {
                                    <span class="text-sm" style="color: var(--color-cloud);">--</span>
                                }
                            </td>
                            <td>
                                @if (site.IsPrimary)
                                {
                                    <span class="badge badge-warning" title="Primary Site">
                                        <svg class="w-3 h-3 inline-block mr-0.5" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                        </svg>
                                        Primary
                                    </span>
                                }
                            </td>
                            <td style="white-space: nowrap;">
                                <span class="text-sm" style="color: var(--color-ash);">@site.CreatedAt.ToString("MMM d, yyyy")</span>
                            </td>
                            <td>
                                <div class="flex items-center gap-1">
                                    @if (!site.IsPrimary)
                                    {
                                        <form method="post" asp-page-handler="SetPrimary" class="inline">
                                            <input type="hidden" name="id" value="@site.Id" />
                                            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-indigo);" title="Set as Primary">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                                                </svg>
                                            </button>
                                        </form>
                                        <form method="post" asp-page-handler="Delete" class="inline">
                                            <input type="hidden" name="id" value="@site.Id" />
                                            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);" title="Delete">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card text-center py-12">
            <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
            </svg>
            <p style="color: var(--color-cloud);">No sites configured.</p>
            <p class="text-sm mt-2" style="color: var(--color-ash);">Create your first site to get started.</p>
        </div>
    }
</div>
