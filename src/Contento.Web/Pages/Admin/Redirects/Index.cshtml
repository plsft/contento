@page "/admin/redirects"
@model Contento.Web.Pages.Admin.Redirects.IndexModel
@{
    ViewData["Title"] = "Redirects";
}

<div class="max-w-5xl mx-auto" x-data="redirectsPage()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Redirects</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">@Model.TotalCount redirects</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Create / Edit Form -->
        <div class="lg:col-span-1">
            <div class="card">
                <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);"
                    x-text="editing ? 'Edit Redirect' : 'Add Redirect'">Add Redirect</h3>

                <form method="post" x-bind:action="editing ? '?handler=Update' : '?handler=Create'">
                    <template x-if="editing">
                        <input type="hidden" name="EditId" x-bind:value="editId" />
                    </template>

                    <div class="space-y-4">
                        <div>
                            <label class="form-label">From Path</label>
                            <input type="text" name="FromPath" x-model="fromPath" class="form-input" placeholder="/old-page" required />
                        </div>
                        <div>
                            <label class="form-label">To Path</label>
                            <input type="text" name="ToPath" x-model="toPath" class="form-input" placeholder="/new-page" required />
                        </div>
                        <div>
                            <label class="form-label">Status Code</label>
                            <select name="StatusCode" x-model="statusCode" class="form-input">
                                <option value="301">301 (Permanent)</option>
                                <option value="302">302 (Temporary)</option>
                            </select>
                        </div>
                        <div>
                            <label class="form-label">Notes</label>
                            <textarea name="Notes" x-model="notes" rows="3" class="form-input" placeholder="Optional notes"></textarea>
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="hidden" name="IsActive" value="false" />
                            <input type="checkbox" name="IsActive" value="true" x-bind:checked="isActive" x-on:change="isActive = $el.checked"
                                   class="rounded" style="color: var(--color-ink);" />
                            <label class="form-label mb-0">Active</label>
                        </div>

                        <div class="flex gap-2">
                            <button type="submit" class="btn btn-primary btn-sm flex-1"
                                    x-text="editing ? 'Update' : 'Add Redirect'">
                                Add Redirect
                            </button>
                            <button type="button" x-show="editing" x-cloak x-on:click="cancelEdit()"
                                    class="btn btn-ghost btn-sm">
                                Cancel
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Redirects List -->
        <div class="lg:col-span-2">
            @if (Model.Redirects.Any())
            {
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>From Path</th>
                                <th>To Path</th>
                                <th>Status</th>
                                <th>Hits</th>
                                <th>Last Hit</th>
                                <th>Active</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Redirects)
                            {
                                <tr>
                                    <td>
                                        <span class="text-xs font-mono font-medium" style="color: var(--color-ink);">@r.FromPath</span>
                                    </td>
                                    <td>
                                        <span class="text-xs font-mono" style="color: var(--color-ash);">@r.ToPath</span>
                                    </td>
                                    <td>
                                        <span class="text-xs px-2 py-0.5 rounded-full"
                                              style="background: var(--color-mist); color: var(--color-ink);">
                                            @r.StatusCode
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-sm" style="color: var(--color-ash);">@r.HitCount</span>
                                    </td>
                                    <td>
                                        <span class="text-xs" style="color: var(--color-ash);">
                                            @(r.LastHitAt?.ToString("yyyy-MM-dd HH:mm") ?? "\u2014")
                                        </span>
                                    </td>
                                    <td>
                                        @if (r.IsActive)
                                        {
                                            <span class="text-xs px-2 py-0.5 rounded-full" style="background: #dcfce7; color: #166534;">Active</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs px-2 py-0.5 rounded-full" style="background: var(--color-mist); color: var(--color-ash);">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="flex items-center gap-1">
                                            <button type="button" class="btn btn-ghost btn-sm"
                                                    x-on:click="startEdit('@r.Id', '@r.FromPath.Replace("'", "\\'")', '@r.ToPath.Replace("'", "\\'")', '@r.StatusCode', '@(r.Notes?.Replace("'", "\\'").Replace("\n", " ") ?? "")', @(r.IsActive ? "true" : "false"))">
                                                Edit
                                            </button>
                                            <form method="post" asp-page-handler="Delete" class="inline">
                                                <input type="hidden" name="id" value="@r.Id" />
                                                <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card text-center py-12">
                    <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                    </svg>
                    <p style="color: var(--color-cloud);">No redirects yet.</p>
                    <p class="text-sm mt-2" style="color: var(--color-ash);">Create your first redirect using the form.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function redirectsPage() {
    return {
        editing: false,
        editId: '',
        fromPath: '',
        toPath: '',
        statusCode: '301',
        notes: '',
        isActive: true,

        startEdit(id, fromPath, toPath, statusCode, notes, isActive) {
            this.editing = true;
            this.editId = id;
            this.fromPath = fromPath;
            this.toPath = toPath;
            this.statusCode = statusCode;
            this.notes = notes;
            this.isActive = isActive;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        },

        cancelEdit() {
            this.editing = false;
            this.editId = '';
            this.fromPath = '';
            this.toPath = '';
            this.statusCode = '301';
            this.notes = '';
            this.isActive = true;
        }
    };
}
</script>
}
