@page "/admin/newsletter"
@model Contento.Web.Pages.Admin.Newsletter.IndexModel
@{
    ViewData["Title"] = "Newsletter";
}

<div class="max-w-5xl mx-auto" x-data="newsletterPage()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Newsletter</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">Send newsletters and manage subscribers</p>
        </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="card">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-indigo-pale);">
                    <svg class="w-5 h-5" style="color: var(--color-indigo);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-semibold" style="color: var(--color-ink);">@Model.SubscriberCount</p>
                    <p class="text-xs" style="color: var(--color-ash);">Active Subscribers</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-indigo-pale);">
                    <svg class="w-5 h-5" style="color: var(--color-indigo);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-semibold" style="color: var(--color-ink);">@Model.Campaigns.Count()</p>
                    <p class="text-xs" style="color: var(--color-ash);">Campaigns Sent</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-indigo-pale);">
                    <svg class="w-5 h-5" style="color: var(--color-indigo);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-2xl font-semibold" style="color: var(--color-ink);">@Model.PublishedPosts.Count()</p>
                    <p class="text-xs" style="color: var(--color-ash);">Published Posts</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Send Newsletter -->
    <div class="card mb-8">
        <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Send Newsletter</h3>
        <p class="text-sm mb-4" style="color: var(--color-ash);">Select a published post to send as a newsletter to all active subscribers.</p>

        <div class="flex flex-col sm:flex-row gap-3">
            <select x-model="selectedPostId" class="form-input flex-1">
                <option value="">Select a post...</option>
                @foreach (var post in Model.PublishedPosts)
                {
                    <option value="@post.Id">@post.Title</option>
                }
            </select>
            <button type="button"
                    class="btn btn-primary btn-sm"
                    :disabled="!selectedPostId || sending"
                    @@click="sendNewsletter()">
                <span x-show="!sending">Send Newsletter</span>
                <span x-show="sending" x-cloak>Sending...</span>
            </button>
        </div>

        <!-- Confirmation dialog -->
        <div x-show="showConfirm" x-cloak class="mt-4 p-4 rounded-lg border" style="border-color: var(--color-warning); background: rgba(var(--color-warning-rgb, 245, 158, 11), 0.05);">
            <p class="text-sm font-medium mb-2" style="color: var(--color-ink);">
                Are you sure you want to send this newsletter to <strong>@Model.SubscriberCount</strong> subscriber@(Model.SubscriberCount != 1 ? "s" : "")?
            </p>
            <div class="flex gap-2">
                <button type="button" class="btn btn-primary btn-sm" @@click="confirmSend()">
                    Yes, Send Now
                </button>
                <button type="button" class="btn btn-ghost btn-sm" @@click="showConfirm = false">
                    Cancel
                </button>
            </div>
        </div>
    </div>

    <!-- Campaign History -->
    <div>
        <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Campaign History</h3>

        @if (Model.Campaigns.Any())
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Subject</th>
                            <th>Status</th>
                            <th>Sent</th>
                            <th>Failed</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var campaign in Model.Campaigns)
                        {
                            <tr>
                                <td>
                                    <span class="font-medium" style="color: var(--color-ink);">@campaign.Subject</span>
                                </td>
                                <td>
                                    @{
                                        var badgeClass = campaign.Status switch
                                        {
                                            "sent" => "badge-success",
                                            "sending" => "badge-info",
                                            "failed" => "badge-danger",
                                            "draft" => "badge-neutral",
                                            _ => "badge-neutral"
                                        };
                                    }
                                    <span class="badge @badgeClass">@campaign.Status</span>
                                </td>
                                <td>
                                    <span class="text-sm" style="color: var(--color-stone);">@campaign.SentCount</span>
                                </td>
                                <td>
                                    <span class="text-sm" style="color: @(campaign.FailedCount > 0 ? "var(--color-danger)" : "var(--color-stone)");">@campaign.FailedCount</span>
                                </td>
                                <td style="white-space: nowrap;">
                                    <span class="text-sm" style="color: var(--color-ash);">
                                        @(campaign.SentAt?.ToString("MMM d, yyyy HH:mm") ?? campaign.CreatedAt.ToString("MMM d, yyyy HH:mm"))
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card text-center py-12">
                <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                <p style="color: var(--color-cloud);">No campaigns sent yet.</p>
                <p class="text-sm mt-2" style="color: var(--color-ash);">Select a published post above to send your first newsletter.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
function newsletterPage() {
    return {
        selectedPostId: '',
        sending: false,
        showConfirm: false,

        sendNewsletter() {
            if (!this.selectedPostId) return;
            this.showConfirm = true;
        },

        async confirmSend() {
            this.showConfirm = false;
            this.sending = true;

            try {
                const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('/api/v1/newsletter/send', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': csrfToken || ''
                    },
                    body: JSON.stringify({ postId: this.selectedPostId })
                });

                const result = await response.json();

                if (response.ok) {
                    Alpine.store('toast').show('Newsletter sent successfully!', 'success');
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    Alpine.store('toast').show(result.error?.message || 'Failed to send newsletter.', 'error');
                }
            } catch (err) {
                Alpine.store('toast').show('An error occurred while sending the newsletter.', 'error');
            } finally {
                this.sending = false;
            }
        }
    };
}
</script>
}
