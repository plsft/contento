@page "/admin/categories"
@model Contento.Web.Pages.Admin.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<div class="max-w-5xl mx-auto" x-data="categoriesPage()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Categories</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">@Model.TotalCount categories</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Create / Edit Form -->
        <div class="lg:col-span-1">
            <div class="card">
                <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);"
                    x-text="editing ? 'Edit Category' : 'Add Category'">Add Category</h3>

                <form method="post" x-bind:action="editing ? '?handler=Update' : '?handler=Create'">
                    <template x-if="editing">
                        <input type="hidden" name="EditId" x-bind:value="editId" />
                    </template>

                    <div class="space-y-4">
                        <div>
                            <label class="form-label">Name</label>
                            <input type="text" name="Name" x-model="name" class="form-input" placeholder="Category name" required />
                        </div>
                        <div>
                            <label class="form-label">Slug</label>
                            <input type="text" name="Slug" x-model="slug" class="form-input" placeholder="auto-generated" />
                        </div>
                        <div>
                            <label class="form-label">Description</label>
                            <textarea name="Description" x-model="description" rows="3" class="form-input" placeholder="Optional description"></textarea>
                        </div>
                        <div>
                            <label class="form-label">Parent Category</label>
                            <select name="ParentId" x-model="parentId" class="form-input">
                                <option value="">None (top-level)</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <div class="flex gap-2">
                            <button type="submit" class="btn btn-primary btn-sm flex-1"
                                    x-text="editing ? 'Update' : 'Add Category'">
                                Add Category
                            </button>
                            <button type="button" x-show="editing" x-cloak x-on:click="cancelEdit()"
                                    class="btn btn-ghost btn-sm">
                                Cancel
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Categories List -->
        <div class="lg:col-span-2">
            @if (Model.Categories.Any())
            {
                <div class="table-container">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Slug</th>
                                <th>Description</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cat in Model.Categories)
                            {
                                <tr>
                                    <td>
                                        <span class="font-medium" style="color: var(--color-ink);">@cat.Name</span>
                                    </td>
                                    <td>
                                        <span class="text-xs font-mono" style="color: var(--color-ash);">@cat.Slug</span>
                                    </td>
                                    <td>
                                        <span class="text-sm" style="color: var(--color-ash);">
                                            @(cat.Description != null && cat.Description.Length > 50 ? cat.Description[..50] + "..." : cat.Description ?? "\u2014")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="flex items-center gap-1">
                                            <button type="button" class="btn btn-ghost btn-sm"
                                                    x-on:click="startEdit('@cat.Id', '@cat.Name.Replace("'", "\\'")', '@cat.Slug', '@(cat.Description?.Replace("'", "\\'").Replace("\n", " ") ?? "")', '@(cat.ParentId?.ToString() ?? "")')">
                                                Edit
                                            </button>
                                            <form method="post" asp-page-handler="Delete" class="inline">
                                                <input type="hidden" name="id" value="@cat.Id" />
                                                <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card text-center py-12">
                    <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                    </svg>
                    <p style="color: var(--color-cloud);">No categories yet.</p>
                    <p class="text-sm mt-2" style="color: var(--color-ash);">Create your first category using the form.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function categoriesPage() {
    return {
        editing: false,
        editId: '',
        name: '',
        slug: '',
        description: '',
        parentId: '',

        startEdit(id, name, slug, description, parentId) {
            this.editing = true;
            this.editId = id;
            this.name = name;
            this.slug = slug;
            this.description = description;
            this.parentId = parentId;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        },

        cancelEdit() {
            this.editing = false;
            this.editId = '';
            this.name = '';
            this.slug = '';
            this.description = '';
            this.parentId = '';
        }
    };
}
</script>
}
