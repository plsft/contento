@page "/admin/network"
@model Contento.Web.Pages.Admin.Network.IndexModel
@{
    ViewData["Title"] = "Network Overview";
}

<div class="max-w-7xl mx-auto">
    <!-- Breadcrumb & Header -->
    <div class="mb-8">
        <nav class="text-sm mb-2" style="color: var(--color-ash);">
            <a href="/admin" class="hover:underline" style="color: var(--color-indigo);">Dashboard</a>
            <span class="mx-1">/</span>
            <span>Network</span>
        </nav>
        <h2 class="text-2xl font-semibold" style="color: var(--color-ink); font-family: var(--font-serif);">
            Network Overview
        </h2>
        <p class="mt-1 text-sm" style="color: var(--color-ash);">
            Aggregate data across all sites in your Contento network
        </p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="card">
            <div class="stat-label">Total Sites</div>
            <div class="stat-value">@Model.Sites.Count()</div>
        </div>
        <div class="card">
            <div class="stat-label">Total Posts</div>
            <div class="stat-value">@Model.TotalPosts</div>
        </div>
        <div class="card">
            <div class="stat-label">Total Users</div>
            <div class="stat-value">@Model.TotalUsers</div>
        </div>
        <div class="card">
            <div class="stat-label">Total Comments</div>
            <div class="stat-value">@Model.TotalComments</div>
        </div>
    </div>

    <!-- Sites Table -->
    <div class="card mb-8">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold" style="color: var(--color-ink);">Sites</h3>
            <span class="text-sm" style="color: var(--color-ash);">@Model.Sites.Count() sites</span>
        </div>

        @if (Model.Sites.Any())
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Domain</th>
                            <th>Status</th>
                            <th>Posts</th>
                            <th>Published</th>
                            <th>Comments</th>
                            <th>Media</th>
                            <th>Plugins</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var site in Model.Sites)
                        {
                            <tr>
                                <td>
                                    <a href="/admin?site=@site.Name.ToLower().Replace(" ", "-")" class="font-medium hover:underline" style="color: var(--color-ink);">
                                        @site.Name
                                    </a>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(site.Domain))
                                    {
                                        <span class="text-sm" style="color: var(--color-stone);">@site.Domain</span>
                                    }
                                    else
                                    {
                                        <span class="text-sm" style="color: var(--color-cloud);">--</span>
                                    }
                                </td>
                                <td>
                                    @if (site.IsPrimary)
                                    {
                                        <span class="badge badge-success">Primary</span>
                                    }
                                </td>
                                <td style="color: var(--color-stone); font-size: 0.8125rem;">@site.PostCount</td>
                                <td style="color: var(--color-stone); font-size: 0.8125rem;">@site.PublishedCount</td>
                                <td style="color: var(--color-stone); font-size: 0.8125rem;">@site.CommentCount</td>
                                <td style="color: var(--color-stone); font-size: 0.8125rem;">@site.MediaCount</td>
                                <td style="color: var(--color-stone); font-size: 0.8125rem;">@site.PluginCount</td>
                                <td style="color: var(--color-ash); font-size: 0.8125rem; white-space: nowrap;">
                                    @site.CreatedAt.ToString("MMM d, yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-center py-8" style="color: var(--color-cloud);">
                No sites configured yet.
            </p>
        }
    </div>

    <!-- Users Table -->
    <div class="card mb-8">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold" style="color: var(--color-ink);">Users</h3>
            <span class="text-sm" style="color: var(--color-ash);">@Model.TotalUsers active users</span>
        </div>

        @if (Model.AllUsers.Any())
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Last Login</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.AllUsers)
                        {
                            var initials = string.Join("", user.DisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();
                            var roleBadge = user.Role switch
                            {
                                "owner" => "background-color: var(--color-indigo); color: white;",
                                "admin" => "background-color: #3b82f6; color: white;",
                                "editor" => "background-color: #22c55e; color: white;",
                                "author" => "background-color: #eab308; color: white;",
                                _ => "background-color: var(--color-cloud); color: white;"
                            };

                            <tr>
                                <td>
                                    <div class="flex items-center gap-3">
                                        <div style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--color-mist); color: var(--color-stone); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 600; flex-shrink: 0;">
                                            @initials
                                        </div>
                                        <span class="font-medium" style="color: var(--color-ink);">@user.DisplayName</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="text-sm" style="color: var(--color-ash);">@user.Email</span>
                                </td>
                                <td>
                                    <span class="badge" style="@roleBadge">@user.Role</span>
                                </td>
                                <td style="color: var(--color-ash); font-size: 0.8125rem; white-space: nowrap;">
                                    @if (user.LastLoginAt.HasValue)
                                    {
                                        @user.LastLoginAt.Value.ToString("MMM d, yyyy")
                                    }
                                    else
                                    {
                                        <span style="color: var(--color-cloud);">Never</span>
                                    }
                                </td>
                                <td>
                                    <a href="/admin/users" class="btn btn-ghost btn-sm">Manage</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-sm text-center py-8" style="color: var(--color-cloud);">
                No active users found.
            </p>
        }
    </div>

    <!-- Quick Actions -->
    <div class="card">
        <h3 class="text-base font-semibold mb-4" style="color: var(--color-ink);">Quick Actions</h3>
        <div class="flex items-center gap-3">
            <a href="/admin/sites" class="btn btn-primary btn-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
                </svg>
                Create New Site
            </a>
            <a href="/admin/users" class="btn btn-sm" style="border: 1px solid var(--color-mist); color: var(--color-stone);">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Manage Users
            </a>
        </div>
    </div>
</div>
