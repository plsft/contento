@page "/admin/login"
@model Contento.Web.Pages.Admin.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - Contento</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <style>
        body {
            background-color: var(--color-paper);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .login-container {
            width: 100%;
            max-width: 400px;
            padding: 0 1.5rem;
        }

        .login-card {
            background: var(--color-snow);
            border: 1px solid var(--color-mist);
            border-radius: 0.75rem;
            padding: 2.5rem;
        }

        .login-divider {
            height: 1px;
            background: var(--color-mist);
            margin: 1.5rem 0;
        }
    </style>
</head>
<body>

<div class="login-container">
    <!-- Logo -->
    <div class="text-center mb-8">
        <div class="w-12 h-12 rounded-lg mx-auto flex items-center justify-center mb-4" style="background-color: var(--color-indigo);">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
        </div>
        <h1 class="text-xl font-semibold" style="color: var(--color-ink); font-family: var(--font-serif);">Contento</h1>
        <p class="text-sm mt-1" style="color: var(--color-ash);">Sign in to your account</p>
    </div>

    <!-- Login Card -->
    <div class="login-card">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-error mb-4">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-sm">@Model.ErrorMessage</span>
            </div>
        }

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />

            <div class="space-y-4">
                <div>
                    <label class="form-label">Email</label>
                    <input type="email" asp-for="Email" class="form-input" placeholder="you@example.com" required autofocus />
                </div>

                <div>
                    <label class="form-label">Password</label>
                    <input type="password" asp-for="Password" class="form-input" placeholder="Enter your password" required />
                </div>
            </div>

            <div class="login-divider"></div>

            <button type="submit" class="btn btn-primary w-full">
                Sign In
            </button>
        </form>
    </div>

    <!-- Footer -->
    <p class="text-center text-xs mt-6" style="color: var(--color-cloud);">
        Contento CMS
    </p>
</div>

</body>
</html>
