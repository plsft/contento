@page "/admin/membership"
@model Contento.Web.Pages.Admin.Membership.IndexModel
@{
    ViewData["Title"] = "Membership";
}

<div class="max-w-5xl mx-auto" x-data="{ tab: '@Model.Tab', showPlanForm: false }">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Membership</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">Manage plans, members, and revenue.</p>
        </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 mb-6 border-b" style="border-color: var(--color-mist);">
        @foreach (var t in new[] { ("dashboard", "Dashboard"), ("plans", "Plans"), ("members", "Members"), ("settings", "Settings") })
        {
            <button x-on:click="tab = '@t.Item1'"
                    class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors"
                    :class="tab === '@t.Item1' ? 'border-[var(--color-indigo)] text-[var(--color-indigo)]' : 'border-transparent text-[var(--color-ash)] hover:text-[var(--color-stone)]'">
                @t.Item2
            </button>
        }
    </div>

    <!-- Dashboard Tab -->
    <div x-show="tab === 'dashboard'" x-cloak>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            <div class="card">
                <p class="text-2xl font-semibold" style="color: var(--color-ink);">@Model.TotalMembers</p>
                <p class="text-sm" style="color: var(--color-ash);">Total Subscribers</p>
            </div>
            <div class="card">
                <p class="text-2xl font-semibold" style="color: var(--color-indigo);">@Model.PremiumMembers</p>
                <p class="text-sm" style="color: var(--color-ash);">Paid Members</p>
            </div>
            <div class="card">
                <p class="text-2xl font-semibold" style="color: var(--color-ink);">@Model.ActivePlans</p>
                <p class="text-sm" style="color: var(--color-ash);">Active Plans</p>
            </div>
        </div>

        <!-- Revenue placeholder -->
        <div class="card text-center py-10">
            <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            <p class="font-medium" style="color: var(--color-stone);">Revenue Analytics</p>
            <p class="text-sm mt-1" style="color: var(--color-ash);">Connect your Stripe dashboard for detailed revenue reports.</p>
        </div>
    </div>

    <!-- Plans Tab -->
    <div x-show="tab === 'plans'" x-cloak>
        <div class="flex justify-end mb-4">
            <button x-on:click="showPlanForm = !showPlanForm" class="btn btn-primary btn-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
                </svg>
                New Plan
            </button>
        </div>

        <!-- Create Plan Form -->
        <div x-show="showPlanForm" x-cloak class="card mb-6">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Create Plan</h3>
            <form method="post" asp-page-handler="CreatePlan">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="form-label">Plan Name</label>
                        <input type="text" asp-for="PlanName" class="form-input" placeholder="e.g. Premium" required />
                    </div>
                    <div>
                        <label class="form-label">Slug</label>
                        <input type="text" asp-for="PlanSlug" class="form-input" placeholder="e.g. premium" required />
                    </div>
                    <div>
                        <label class="form-label">Price</label>
                        <input type="number" asp-for="PlanPrice" step="0.01" class="form-input" placeholder="9.99" required />
                    </div>
                    <div>
                        <label class="form-label">Billing Interval</label>
                        <select asp-for="PlanInterval" class="form-input">
                            <option value="monthly">Monthly</option>
                            <option value="yearly">Yearly</option>
                            <option value="lifetime">Lifetime</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Stripe Price ID</label>
                        <input type="text" asp-for="PlanStripePriceId" class="form-input" placeholder="price_..." />
                    </div>
                    <div>
                        <label class="form-label">Trial Days</label>
                        <input type="number" asp-for="PlanTrialDays" class="form-input" min="0" />
                    </div>
                    <div>
                        <label class="form-label">Access Level</label>
                        <input type="number" asp-for="PlanAccessLevel" class="form-input" min="1" />
                        <p class="text-xs mt-1" style="color: var(--color-cloud);">Higher = more access. Used for content gating.</p>
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label">Description</label>
                    <input type="text" asp-for="PlanDescription" class="form-input" placeholder="Short description..." />
                </div>
                <div class="mb-4">
                    <label class="form-label">Features (one per line)</label>
                    <textarea asp-for="PlanFeatures" class="form-input" rows="4" placeholder="Access to all posts&#10;Premium newsletter&#10;Priority support"></textarea>
                </div>
                <div class="flex gap-3 justify-end">
                    <button type="button" x-on:click="showPlanForm = false" class="btn btn-ghost">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Plan</button>
                </div>
            </form>
        </div>

        <!-- Plans Table -->
        @if (Model.Plans.Any())
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Price</th>
                            <th>Interval</th>
                            <th>Trial</th>
                            <th>Access</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var plan in Model.Plans)
                        {
                            <tr>
                                <td>
                                    <span class="font-medium" style="color: var(--color-ink);">@plan.Name</span>
                                    <span class="text-xs block" style="color: var(--color-ash);">@plan.Slug</span>
                                </td>
                                <td>
                                    <span style="color: var(--color-ink);">$@plan.Price.ToString("F2")</span>
                                </td>
                                <td>
                                    <span class="text-sm" style="color: var(--color-ash);">@plan.BillingInterval</span>
                                </td>
                                <td>
                                    <span class="text-sm" style="color: var(--color-ash);">@(plan.TrialDays > 0 ? $"{plan.TrialDays} days" : "—")</span>
                                </td>
                                <td>
                                    <span class="text-sm" style="color: var(--color-ash);">Level @plan.AccessLevel</span>
                                </td>
                                <td>
                                    <span class="badge @(plan.IsActive ? "badge-success" : "badge-neutral")">
                                        @(plan.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <form method="post" asp-page-handler="DeletePlan" class="inline">
                                        <input type="hidden" name="id" value="@plan.Id" />
                                        <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);"
                                                onclick="return confirm('Delete this plan?')">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card text-center py-12">
                <p style="color: var(--color-cloud);">No plans created yet.</p>
                <p class="text-sm mt-2" style="color: var(--color-ash);">Create your first membership plan to start accepting payments.</p>
            </div>
        }
    </div>

    <!-- Members Tab -->
    <div x-show="tab === 'members'" x-cloak>
        @if (Model.Members.Any())
        {
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Tier</th>
                            <th>Status</th>
                            <th>Stripe Customer</th>
                            <th>Expires</th>
                            <th>Joined</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in Model.Members)
                        {
                            <tr>
                                <td>
                                    <span class="font-medium" style="color: var(--color-ink);">@member.Email</span>
                                </td>
                                <td>
                                    @{
                                        var tierColor = member.MembershipTier switch
                                        {
                                            "premium" => "var(--color-indigo)",
                                            "vip" => "#d97706",
                                            _ => "var(--color-ash)"
                                        };
                                        var tierBg = member.MembershipTier switch
                                        {
                                            "premium" => "var(--color-indigo-pale)",
                                            "vip" => "#fef3c7",
                                            _ => "var(--color-cloud)"
                                        };
                                    }
                                    <span class="px-2 py-0.5 rounded text-xs font-medium"
                                          style="color: @tierColor; background: @tierBg;">
                                        @member.MembershipTier.ToUpperInvariant()
                                    </span>
                                </td>
                                <td>
                                    @if (member.MembershipExpiresAt.HasValue && member.MembershipExpiresAt.Value > DateTime.UtcNow)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else if (member.MembershipTier != "free")
                                    {
                                        <span class="badge badge-danger">Expired</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-neutral">Free</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-xs font-mono" style="color: var(--color-ash);">
                                        @(member.StripeCustomerId ?? "\u2014")
                                    </span>
                                </td>
                                <td>
                                    <span class="text-sm" style="color: var(--color-ash);">
                                        @(member.MembershipExpiresAt?.ToString("MMM d, yyyy") ?? "\u2014")
                                    </span>
                                </td>
                                <td>
                                    <span class="text-sm" style="color: var(--color-ash);">
                                        @member.CreatedAt.ToString("MMM d, yyyy")
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card text-center py-12">
                <p style="color: var(--color-cloud);">No members yet.</p>
                <p class="text-sm mt-2" style="color: var(--color-ash);">Members will appear here once subscribers sign up.</p>
            </div>
        }
    </div>

    <!-- Settings Tab -->
    <div x-show="tab === 'settings'" x-cloak>
        <div class="card mb-6">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Membership Settings</h3>
            <div class="space-y-4">
                <div>
                    <label class="form-label">Grace Period (days)</label>
                    <input type="number" value="3" class="form-input max-w-xs" min="0" />
                    <p class="text-xs mt-1" style="color: var(--color-cloud);">Number of days to maintain access after membership expires.</p>
                </div>
                <div>
                    <label class="form-label">Dunning Email Template</label>
                    <textarea class="form-input" rows="3" placeholder="Your payment failed. Please update your payment method at {portal_url} to keep your membership active."></textarea>
                    <p class="text-xs mt-1" style="color: var(--color-cloud);">Sent when a subscriber's payment fails. Use {portal_url} for the Stripe billing portal link.</p>
                </div>
                <div>
                    <label class="form-label">Drip Content Default Delay (days)</label>
                    <input type="number" value="0" class="form-input max-w-xs" min="0" />
                    <p class="text-xs mt-1" style="color: var(--color-cloud);">Default delay before new members can access drip content. 0 = immediate access.</p>
                </div>
            </div>
        </div>
    </div>
</div>
