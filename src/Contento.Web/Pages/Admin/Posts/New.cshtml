@page "/admin/posts/new"
@model Contento.Web.Pages.Admin.Posts.NewModel
@{
    ViewData["Title"] = "New Post";
    Layout = null; // Full-page editor
}
<!DOCTYPE html>
<html lang="en" class="h-full" :class="$store.darkMode.on ? 'dark' : ''">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Post - Contento</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    <style>
        [x-cloak] { display: none !important; }
        body { background-color: var(--color-paper); color: var(--color-ink); }

        .editor-title {
            font-family: var(--font-serif);
            font-size: 2.5rem;
            font-weight: 700;
            line-height: 1.15;
            color: var(--color-ink);
            border: none;
            outline: none;
            width: 100%;
            background: transparent;
            resize: none;
            overflow: hidden;
        }
        .editor-title::placeholder { color: var(--color-cloud); }

        .editor-subtitle {
            font-family: var(--font-serif);
            font-size: 1.25rem;
            font-weight: 400;
            line-height: 1.5;
            color: var(--color-stone);
            border: none;
            outline: none;
            width: 100%;
            background: transparent;
            resize: none;
            overflow: hidden;
        }
        .editor-subtitle::placeholder { color: var(--color-cloud); }

        .editor-body {
            font-family: var(--font-serif);
            font-size: 1.125rem;
            line-height: 1.8;
            color: var(--color-ink);
            border: none;
            outline: none;
            width: 100%;
            background: transparent;
            resize: none;
            min-height: 60vh;
        }
        .editor-body::placeholder { color: var(--color-cloud); }
    </style>
</head>
<body class="h-full">

<div x-data="newPostEditor()" class="h-full flex flex-col">
    <!-- Top bar -->
    <header class="h-14 flex items-center justify-between px-4 border-b" style="border-color: var(--color-mist); background: var(--color-snow); backdrop-filter: blur(8px);">
        <a href="/admin/posts" class="p-2 rounded hover:bg-stone-100 transition-colors" style="color: var(--color-ash);">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
        </a>
        <div class="flex items-center gap-3">
            <div class="flex items-center gap-2">
                <div class="save-indicator" :class="{ 'saving': justSaved }"></div>
            </div>
            <!-- Dark mode toggle -->
            <button @@click="$store.darkMode.toggle()" class="btn btn-ghost btn-sm" title="Toggle dark mode">
                <template x-if="$store.darkMode.on">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                </template>
                <template x-if="!$store.darkMode.on">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    </svg>
                </template>
            </button>
            <!-- AI Assistant toggle -->
            <button @@click="showAi = !showAi" class="btn btn-ghost btn-sm" title="AI Writing Assistant">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                </svg>
                AI
            </button>
            <button @@click="saveDraft()" class="btn btn-secondary btn-sm">Save Draft</button>
            <button @@click="publish()" class="btn btn-primary btn-sm">Publish</button>
        </div>
    </header>

    <!-- AI Suggestion Bar -->
    <div x-show="showAi" x-cloak class="px-6 py-3 border-b flex items-start gap-4" style="border-color: var(--color-mist); background: var(--color-snow);">
        <div class="flex-1">
            <div class="flex items-center gap-2 mb-2">
                <svg class="w-4 h-4" style="color: var(--color-indigo);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                </svg>
                <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-ash);">AI Suggestions</span>
            </div>
            <div class="flex gap-2 flex-wrap">
                <button @@click="aiGenerate('outline')" :disabled="aiLoading" class="btn btn-secondary btn-sm">Generate Outline</button>
                <button @@click="aiGenerate('titles')" :disabled="aiLoading" class="btn btn-secondary btn-sm">Suggest Titles</button>
            </div>
            <div x-show="aiLoading" class="flex items-center gap-2 mt-2">
                <svg class="animate-spin h-3 w-3" style="color: var(--color-indigo)" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-xs" style="color: var(--color-ash);">Generating...</span>
            </div>
            <div x-show="aiError" x-cloak class="text-xs mt-2 text-red-600" x-text="aiError"></div>
            <div x-show="aiResult && !aiLoading" x-cloak class="mt-2">
                <div class="text-sm rounded p-3 mb-2" style="background: var(--color-paper); border: 1px solid var(--color-mist); white-space: pre-wrap;" x-text="aiResult"></div>
                <div class="flex gap-2">
                    <button @@click="bodyMarkdown = aiResult; aiResult = ''" class="btn btn-primary btn-sm">Use as Body</button>
                    <button @@click="navigator.clipboard.writeText(aiResult)" class="btn btn-secondary btn-sm">Copy</button>
                    <button @@click="aiResult = ''" class="btn btn-ghost btn-sm">Dismiss</button>
                </div>
            </div>
        </div>
        <button @@click="showAi = false" class="p-1 rounded hover:bg-stone-100 flex-shrink-0">
            <svg class="w-4 h-4" style="color: var(--color-ash);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <!-- Editor -->
    <div class="flex-1 overflow-y-auto">
        <div class="max-w-[720px] mx-auto px-6 py-12">
            <textarea x-model="title"
                      @@input="autoResize($event)"
                      @@keydown.enter.prevent="$refs.subtitle.focus()"
                      placeholder="Title"
                      class="editor-title mb-2"
                      rows="1"
                      autofocus></textarea>

            <textarea x-ref="subtitle"
                      x-model="subtitle"
                      @@input="autoResize($event)"
                      @@keydown.enter.prevent="$refs.body.focus()"
                      placeholder="Tell your story..."
                      class="editor-subtitle mb-8"
                      rows="1"></textarea>

            <textarea x-ref="body"
                      x-model="bodyMarkdown"
                      @@input="autoResize($event); updateWordCount()"
                      placeholder="Start writing..."
                      class="editor-body"
                      rows="20"></textarea>
        </div>
    </div>

    <!-- Bottom bar -->
    <footer class="h-10 flex items-center px-6 border-t" style="border-color: var(--color-mist); background: var(--color-snow);">
        <span class="text-xs" style="color: var(--color-ash);" x-text="wordCount + ' words · ' + readingTime + ' min read'"></span>
    </footer>
</div>

<script>
function newPostEditor() {
    return {
        title: '',
        subtitle: '',
        bodyMarkdown: '',
        wordCount: 0,
        readingTime: 0,
        justSaved: false,
        showAi: false,
        aiLoading: false,
        aiResult: '',
        aiError: '',
        aiAbortController: null,

        autoResize(event) {
            const el = event.target;
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
        },

        updateWordCount() {
            const text = this.bodyMarkdown.trim();
            this.wordCount = text ? text.split(/\s+/).length : 0;
            this.readingTime = Math.max(1, Math.ceil(this.wordCount / 250));
        },

        async saveDraft() {
            await this.createPost('draft');
        },

        async publish() {
            await this.createPost('published');
        },

        async aiGenerate(action) {
            const topic = this.title || this.bodyMarkdown || 'a blog post';
            let userPrompt;
            if (action === 'outline') {
                userPrompt = `Generate a detailed outline for an article about: ${topic}`;
            } else {
                userPrompt = `Generate 5 compelling title options for an article about: ${topic}`;
            }

            this.aiResult = '';
            this.aiError = '';
            this.aiLoading = true;
            if (this.aiAbortController) { this.aiAbortController.abort(); this.aiAbortController = null; }

            const systemPrompt = 'You are a writing assistant. Respond only with the requested content in markdown. No preamble.';

            try {
                this.aiAbortController = new AbortController();
                const response = await fetch('/api/v1/ai/stream', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ systemPrompt, userPrompt }),
                    signal: this.aiAbortController.signal
                });
                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let buffer = '';
                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;
                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n');
                    buffer = lines.pop();
                    for (const line of lines) {
                        if (!line.startsWith('data: ')) continue;
                        const payload = line.slice(6);
                        if (payload === '[DONE]') { this.aiLoading = false; return; }
                        try {
                            const data = JSON.parse(payload);
                            if (data.error) { this.aiError = data.error; this.aiLoading = false; return; }
                            if (data.text) this.aiResult += data.text;
                        } catch (e) {}
                    }
                }
                this.aiLoading = false;
            } catch (e) {
                if (e.name !== 'AbortError') this.aiError = 'Failed: ' + e.message;
                this.aiLoading = false;
            }
        },

        async createPost(status) {
            try {
                const response = await fetch('/api/v1/posts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        title: this.title,
                        subtitle: this.subtitle,
                        bodyMarkdown: this.bodyMarkdown,
                        status: status
                    })
                });
                if (response.ok) {
                    const data = await response.json();
                    window.location.href = `/admin/posts/${data.data.id}/edit`;
                }
            } catch (e) {
                console.error('Create failed:', e);
            }
        }
    };
}
</script>

<script>
    document.addEventListener('alpine:init', () => {
        Alpine.store('darkMode', {
            on: localStorage.getItem('contento-dark') === 'true' ||
                (!localStorage.getItem('contento-dark') && window.matchMedia('(prefers-color-scheme: dark)').matches),
            toggle() {
                this.on = !this.on;
                localStorage.setItem('contento-dark', this.on);
            }
        });
    });
</script>
</body>
</html>
