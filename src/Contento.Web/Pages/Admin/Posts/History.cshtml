@page "/admin/posts/{id}/history"
@model Contento.Web.Pages.Admin.Posts.HistoryModel
@{
    ViewData["Title"] = "Post History";
}

<div class="max-w-5xl mx-auto" x-data="versionHistory()">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        @if (Model.CurrentPost != null)
        {
            <a href="/admin/posts/@Model.CurrentPost.Id/edit" class="p-2 rounded hover:bg-stone-100 transition-colors" style="color: var(--color-ash);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
            </a>
        }
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Version History</h2>
            @if (Model.CurrentPost != null)
            {
                <p class="text-sm mt-1" style="color: var(--color-ash);">
                    @Model.CurrentPost.Title
                    <span class="ml-2 badge badge-neutral">v@Model.CurrentPost.Version</span>
                </p>
            }
        </div>
    </div>

    @if (Model.CurrentPost != null)
    {
        <!-- Current Version Info -->
        <div class="card mb-6">
            <div class="flex items-center justify-between">
                <div>
                    <h3 class="text-sm font-semibold" style="color: var(--color-ink);">Current Version</h3>
                    <p class="text-sm mt-1" style="color: var(--color-ash);">
                        Version @Model.CurrentPost.Version &middot; Last updated @Model.CurrentPost.UpdatedAt.ToString("MMM d, yyyy HH:mm")
                    </p>
                </div>
                <span class="badge @(Model.CurrentPost.Status switch { "published" => "badge-success", "draft" => "badge-neutral", "scheduled" => "badge-warning", "archived" => "badge-danger", _ => "badge-neutral" })">
                    @Model.CurrentPost.Status
                </span>
            </div>
        </div>

        <!-- Versions Table -->
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Version</th>
                        <th>Title</th>
                        <th>Changed By</th>
                        <th>Change Summary</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Versions.Any())
                    {
                        @foreach (var version in Model.Versions)
                        {
                            <tr>
                                <td>
                                    <span class="badge badge-info">v@version.Version</span>
                                </td>
                                <td>
                                    <span class="text-sm font-medium" style="color: var(--color-ink);">
                                        @(version.Title ?? "(untitled)")
                                    </span>
                                </td>
                                <td>
                                    <span class="text-sm font-mono" style="color: var(--color-ash);">
                                        @version.ChangedBy.ToString("N")[..8]
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(version.ChangeSummary))
                                    {
                                        <span class="text-sm" style="color: var(--color-stone);">@version.ChangeSummary</span>
                                    }
                                    else
                                    {
                                        <span class="text-sm" style="color: var(--color-cloud);">--</span>
                                    }
                                </td>
                                <td style="white-space: nowrap;">
                                    <span class="text-sm" style="color: var(--color-ash);">@version.CreatedAt.ToString("MMM d, yyyy HH:mm")</span>
                                </td>
                                <td>
                                    <div class="flex items-center gap-2">
                                        <button @@click="compareVersion(@version.Version)"
                                                class="btn btn-secondary btn-sm"
                                                :class="selectedVersion === @version.Version && 'ring-2 ring-indigo-400'">
                                            Compare
                                        </button>
                                        <form method="post" asp-page-handler="Restore"
                                              asp-route-id="@Model.CurrentPost.Id"
                                              asp-route-versionId="@version.Id"
                                              onsubmit="return confirm('Restore this version? The current content will be overwritten.');">
                                            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">
                                                Restore
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-12">
                                <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                                <p style="color: var(--color-cloud);">No version history yet.</p>
                                <p class="text-xs mt-1" style="color: var(--color-cloud);">Versions are created automatically when the post is updated.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Diff Panel -->
        <div x-show="showDiff" x-cloak x-transition class="mt-6">
            <div class="card">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-sm font-semibold" style="color: var(--color-ink);">
                        Comparing v<span x-text="selectedVersion"></span> with Current (v@Model.CurrentPost.Version)
                    </h3>
                    <button @@click="showDiff = false; selectedVersion = null" class="btn btn-ghost btn-sm">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                        Close
                    </button>
                </div>

                <!-- Title Diff -->
                <div class="mb-4">
                    <h4 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--color-ash);">Title</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-3 rounded text-sm" style="background: var(--color-paper); border: 1px solid var(--color-mist);">
                            <div class="text-xs font-semibold mb-1" style="color: var(--color-ash);">Version <span x-text="selectedVersion"></span></div>
                            <div x-html="diffTitle.old"></div>
                        </div>
                        <div class="p-3 rounded text-sm" style="background: var(--color-paper); border: 1px solid var(--color-mist);">
                            <div class="text-xs font-semibold mb-1" style="color: var(--color-ash);">Current (v@Model.CurrentPost.Version)</div>
                            <div x-html="diffTitle.current"></div>
                        </div>
                    </div>
                </div>

                <!-- Body Diff -->
                <div>
                    <h4 class="text-xs font-semibold uppercase tracking-wider mb-2" style="color: var(--color-ash);">Body</h4>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-3 rounded text-sm overflow-auto" style="background: var(--color-paper); border: 1px solid var(--color-mist); max-height: 500px; white-space: pre-wrap; font-family: monospace; font-size: 0.8rem;">
                            <div class="text-xs font-semibold mb-1" style="color: var(--color-ash);">Version <span x-text="selectedVersion"></span></div>
                            <div x-html="diffBody.old"></div>
                        </div>
                        <div class="p-3 rounded text-sm overflow-auto" style="background: var(--color-paper); border: 1px solid var(--color-mist); max-height: 500px; white-space: pre-wrap; font-family: monospace; font-size: 0.8rem;">
                            <div class="text-xs font-semibold mb-1" style="color: var(--color-ash);">Current (v@Model.CurrentPost.Version)</div>
                            <div x-html="diffBody.current"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card text-center py-16">
            <p style="color: var(--color-cloud);">Post not found.</p>
            <a href="/admin/posts" class="btn btn-primary btn-sm mt-4">Back to Posts</a>
        </div>
    }
</div>

@if (Model.CurrentPost != null)
{
<script>
function versionHistory() {
    // Inline version data from the server
    const versions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Versions.Select(v => new {
            version = v.Version,
            title = v.Title ?? "",
            bodyMarkdown = v.BodyMarkdown ?? ""
        })
    ));

    const currentTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CurrentPost.Title ?? ""));
    const currentBody = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CurrentPost.BodyMarkdown ?? ""));

    return {
        selectedVersion: null,
        showDiff: false,
        diffTitle: { old: '', current: '' },
        diffBody: { old: '', current: '' },

        compareVersion(versionNum) {
            if (this.selectedVersion === versionNum && this.showDiff) {
                this.showDiff = false;
                this.selectedVersion = null;
                return;
            }

            this.selectedVersion = versionNum;
            const versionData = versions.find(v => v.version === versionNum);
            if (!versionData) return;

            this.diffTitle = this.computeLineDiff(
                versionData.title,
                currentTitle
            );
            this.diffBody = this.computeLineDiff(
                versionData.bodyMarkdown,
                currentBody
            );
            this.showDiff = true;
        },

        computeLineDiff(oldText, newText) {
            const oldLines = oldText.split('\n');
            const newLines = newText.split('\n');

            // Simple line-by-line diff
            const maxLen = Math.max(oldLines.length, newLines.length);
            let oldHtml = '';
            let newHtml = '';

            for (let i = 0; i < maxLen; i++) {
                const oldLine = i < oldLines.length ? oldLines[i] : null;
                const newLine = i < newLines.length ? newLines[i] : null;

                const escOld = oldLine !== null ? this.escapeHtml(oldLine) : '';
                const escNew = newLine !== null ? this.escapeHtml(newLine) : '';

                if (oldLine === null) {
                    // Line only in new
                    newHtml += '<div style="background: #d4edda; padding: 1px 4px;">' + (escNew || '&nbsp;') + '</div>';
                } else if (newLine === null) {
                    // Line only in old
                    oldHtml += '<div style="background: #f8d7da; padding: 1px 4px;">' + (escOld || '&nbsp;') + '</div>';
                } else if (oldLine !== newLine) {
                    // Lines differ
                    oldHtml += '<div style="background: #f8d7da; padding: 1px 4px;">' + (escOld || '&nbsp;') + '</div>';
                    newHtml += '<div style="background: #d4edda; padding: 1px 4px;">' + (escNew || '&nbsp;') + '</div>';
                } else {
                    // Lines match
                    oldHtml += '<div style="padding: 1px 4px;">' + (escOld || '&nbsp;') + '</div>';
                    newHtml += '<div style="padding: 1px 4px;">' + (escNew || '&nbsp;') + '</div>';
                }
            }

            return { old: oldHtml, current: newHtml };
        },

        escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    };
}
</script>
}
