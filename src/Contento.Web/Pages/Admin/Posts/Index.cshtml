@page "/admin/posts"
@model Contento.Web.Pages.Admin.Posts.IndexModel
@{
    ViewData["Title"] = "Posts";
}

<div class="max-w-7xl mx-auto" x-data="{ activeTab: '@Model.Status' }">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Posts</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">@Model.TotalCount total posts</p>
        </div>
        <a href="/admin/posts/new" class="btn btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
            New Post
        </a>
    </div>

    <!-- Status Tabs -->
    <div class="flex gap-1 mb-6 border-b" style="border-color: var(--color-mist);">
        @foreach (var tab in new[] { ("all", "All"), ("draft", "Drafts"), ("published", "Published"), ("scheduled", "Scheduled"), ("archived", "Archived") })
        {
            <a href="/admin/posts?status=@tab.Item1"
               class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors @(Model.Status == tab.Item1 ? "border-[var(--color-indigo)] text-[var(--color-indigo)]" : "border-transparent text-[var(--color-ash)] hover:text-[var(--color-stone)]")">
                @tab.Item2
            </a>
        }
    </div>

    <!-- Search & Filter -->
    <div class="mb-6">
        <form method="get" class="flex gap-3 flex-wrap">
            <input type="hidden" name="status" value="@Model.Status" />
            <input type="text" name="q" value="@Model.SearchQuery" placeholder="Search posts..."
                   class="form-input max-w-sm" />
            @if (Model.PostTypes.Any())
            {
                <select name="postTypeSlug" class="form-input max-w-xs">
                    <option value="">All Types</option>
                    @foreach (var pt in Model.PostTypes)
                    {
                        <option value="@pt.Slug" selected="@(Model.PostTypeSlug == pt.Slug)">@pt.Name</option>
                    }
                </select>
            }
            <noundry-button type="submit" variant="secondary">Search</noundry-button>
        </form>
    </div>

    <!-- Posts Table -->
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Words</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Posts.Any())
                {
                    @foreach (var post in Model.Posts)
                    {
                        <tr>
                            <td>
                                <a href="/admin/posts/@post.Id/edit" class="font-medium hover:underline" style="color: var(--color-ink);">
                                    @post.Title
                                </a>
                                @if (post.Featured)
                                {
                                    <span class="badge badge-info ml-2">Featured</span>
                                }
                            </td>
                            <td style="color: var(--color-ash);">—</td>
                            <td>
                                <span class="badge @(post.Status switch { "published" => "badge-success", "draft" => "badge-neutral", "scheduled" => "badge-warning", "archived" => "badge-danger", _ => "badge-neutral" })">
                                    @post.Status
                                </span>
                            </td>
                            <td style="color: var(--color-ash); font-size: 0.8125rem;">
                                @(post.PublishedAt?.ToString("MMM d, yyyy") ?? post.UpdatedAt.ToString("MMM d, yyyy"))
                            </td>
                            <td style="color: var(--color-ash); font-size: 0.8125rem;">
                                @(post.WordCount ?? 0)
                            </td>
                            <td>
                                <a href="/admin/posts/@post.Id/edit" class="btn btn-ghost btn-sm">Edit</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-12">
                            <p style="color: var(--color-cloud);">No posts found.</p>
                            <a href="/admin/posts/new" class="btn btn-primary btn-sm mt-4">Create your first post</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-center gap-2 mt-6">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <a href="/admin/posts?status=@Model.Status&q=@Model.SearchQuery&page=@i"
                   class="px-3 py-1.5 text-sm rounded @(i == Model.Page ? "btn-primary text-white" : "hover:bg-stone-100")"
                   style="@(i == Model.Page ? "background-color: var(--color-indigo); color: white;" : "color: var(--color-stone);")">
                    @i
                </a>
            }
        </div>
    }
</div>
