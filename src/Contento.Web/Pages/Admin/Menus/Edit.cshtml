@page "/admin/menus/{id:guid}"
@model Contento.Web.Pages.Admin.Menus.EditModel
@{
    ViewData["Title"] = $"Edit Menu — {Model.Menu.Name}";
}

<div class="max-w-5xl mx-auto" x-data="menuEditor()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <div class="flex items-center gap-2">
                <a asp-page="Index" class="text-sm" style="color: var(--color-ash);">Menus</a>
                <span style="color: var(--color-cloud);">/</span>
                <h2 class="text-xl font-semibold" style="color: var(--color-ink);">@Model.Menu.Name</h2>
            </div>
            <p class="text-sm mt-1" style="color: var(--color-ash);">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium"
                      style="background: var(--color-mist); color: var(--color-stone);">
                    @Model.Menu.Location
                </span>
            </p>
        </div>
    </div>

    <!-- Menu Settings -->
    <div class="card mb-6">
        <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Menu Settings</h3>
        <form method="post" asp-page-handler="UpdateMenu" asp-route-id="@Model.Menu.Id">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div>
                    <label class="form-label">Name</label>
                    <input type="text" name="MenuName" value="@Model.MenuName" class="form-input" required />
                </div>
                <div>
                    <label class="form-label">Location</label>
                    <select name="MenuLocation" class="form-input">
                        <option value="header" selected="@(Model.MenuLocation == "header")">Header</option>
                        <option value="footer" selected="@(Model.MenuLocation == "footer")">Footer</option>
                        <option value="custom" selected="@(Model.MenuLocation == "custom")">Custom</option>
                    </select>
                </div>
                <div class="flex items-end gap-2">
                    <div class="flex items-center gap-2 mb-2">
                        <input type="checkbox" name="MenuIsActive" value="true" checked="@Model.MenuIsActive" class="rounded" />
                        <label class="form-label mb-0">Active</label>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm mb-1">Save</button>
                </div>
            </div>
        </form>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Add / Edit Item Form -->
        <div class="lg:col-span-1">
            <div class="card">
                <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);"
                    x-text="editing ? 'Edit Item' : 'Add Item'">Add Item</h3>

                <form method="post"
                      x-bind:action="editing
                          ? '?handler=UpdateItem&id=@Model.Menu.Id'
                          : '?handler=AddItem&id=@Model.Menu.Id'">

                    <template x-if="editing">
                        <input type="hidden" name="EditItemId" x-bind:value="editItemId" />
                    </template>

                    <div class="space-y-4">
                        <!-- Link Type -->
                        <div>
                            <label class="form-label">Type</label>
                            <select name="LinkType" x-model="linkType" class="form-input">
                                <option value="custom">Custom Link</option>
                                <option value="post">Post</option>
                                <option value="category">Category</option>
                                <option value="tag">Tag</option>
                            </select>
                        </div>

                        <!-- Label -->
                        <div>
                            <label class="form-label">Label</label>
                            <input type="text" name="Label" x-model="label" class="form-input" placeholder="Menu item text" required />
                        </div>

                        <!-- Custom URL -->
                        <div x-show="linkType === 'custom'" x-cloak>
                            <label class="form-label">URL</label>
                            <input type="text" name="Url" x-model="url" class="form-input" placeholder="https://... or /path" />
                        </div>

                        <!-- Post selector -->
                        <div x-show="linkType === 'post'" x-cloak>
                            <label class="form-label">Post</label>
                            <select name="LinkId" x-model="linkId" class="form-input">
                                <option value="">Select a post...</option>
                                @foreach (var post in Model.Posts)
                                {
                                    <option value="@post.Id">@post.Title</option>
                                }
                            </select>
                        </div>

                        <!-- Category selector -->
                        <div x-show="linkType === 'category'" x-cloak>
                            <label class="form-label">Category</label>
                            <select name="LinkId" x-model="linkId" class="form-input">
                                <option value="">Select a category...</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Tag input -->
                        <div x-show="linkType === 'tag'" x-cloak>
                            <label class="form-label">Tag</label>
                            <input type="text" name="Url" x-model="url" class="form-input" placeholder="tag-name" />
                        </div>

                        <!-- Target -->
                        <div>
                            <label class="form-label">Open in</label>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-1 text-sm" style="color: var(--color-stone);">
                                    <input type="radio" name="Target" value="_self" x-model="target" /> Same tab
                                </label>
                                <label class="flex items-center gap-1 text-sm" style="color: var(--color-stone);">
                                    <input type="radio" name="Target" value="_blank" x-model="target" /> New tab
                                </label>
                            </div>
                        </div>

                        <!-- Parent item -->
                        <div>
                            <label class="form-label">Parent</label>
                            <select name="ParentId" x-model="parentId" class="form-input">
                                <option value="">None (top-level)</option>
                                @foreach (var item in Model.Items.Where(i => i.ParentId == null))
                                {
                                    <option value="@item.Id">@item.Label</option>
                                }
                            </select>
                        </div>

                        <div class="flex gap-2">
                            <button type="submit" class="btn btn-primary btn-sm flex-1"
                                    x-text="editing ? 'Update Item' : 'Add Item'">
                                Add Item
                            </button>
                            <button type="button" x-show="editing" x-cloak x-on:click="cancelEdit()"
                                    class="btn btn-ghost btn-sm">
                                Cancel
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Items List -->
        <div class="lg:col-span-2">
            @if (Model.Items.Any())
            {
                <div class="space-y-2">
                    @foreach (var item in Model.Items)
                    {
                        var isNested = item.ParentId != null;
                        <div class="card flex items-center gap-3 py-3 @(isNested ? "ml-8" : "")">
                            <!-- Reorder buttons -->
                            <div class="flex flex-col gap-0.5">
                                <form method="post" asp-page-handler="MoveUp" asp-route-id="@Model.Menu.Id" asp-route-itemId="@item.Id" class="inline">
                                    <button type="submit" class="p-0.5 rounded" style="color: var(--color-ash);" title="Move up">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
                                        </svg>
                                    </button>
                                </form>
                                <form method="post" asp-page-handler="MoveDown" asp-route-id="@Model.Menu.Id" asp-route-itemId="@item.Id" class="inline">
                                    <button type="submit" class="p-0.5 rounded" style="color: var(--color-ash);" title="Move down">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>

                            <!-- Item info -->
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-2">
                                    <span class="font-medium text-sm" style="color: var(--color-ink);">@item.Label</span>
                                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs"
                                          style="background: var(--color-mist); color: var(--color-ash);">
                                        @item.LinkType
                                    </span>
                                    @if (item.Target == "_blank")
                                    {
                                        <svg class="w-3 h-3" style="color: var(--color-ash);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                                        </svg>
                                    }
                                </div>
                                <p class="text-xs truncate" style="color: var(--color-ash);">@(item.Url ?? $"Link: {item.LinkId}")</p>
                            </div>

                            <!-- Actions -->
                            <div class="flex items-center gap-1">
                                <button type="button" class="btn btn-ghost btn-sm"
                                        x-on:click="startEdit('@item.Id', '@item.Label.Replace("'", "\\'")', '@(item.Url?.Replace("'", "\\'") ?? "")', '@item.LinkType', '@(item.LinkId?.ToString() ?? "")', '@item.Target', '@(item.ParentId?.ToString() ?? "")')">
                                    Edit
                                </button>
                                <form method="post" asp-page-handler="DeleteItem" asp-route-id="@Model.Menu.Id" asp-route-itemId="@item.Id" class="inline">
                                    <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">Delete</button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card text-center py-12">
                    <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h7"/>
                    </svg>
                    <p style="color: var(--color-cloud);">No items in this menu.</p>
                    <p class="text-sm mt-2" style="color: var(--color-ash);">Add items using the form on the left.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function menuEditor() {
    return {
        editing: false,
        editItemId: '',
        label: '',
        url: '',
        linkType: 'custom',
        linkId: '',
        target: '_self',
        parentId: '',

        startEdit(id, label, url, linkType, linkId, target, parentId) {
            this.editing = true;
            this.editItemId = id;
            this.label = label;
            this.url = url;
            this.linkType = linkType;
            this.linkId = linkId;
            this.target = target;
            this.parentId = parentId;
            window.scrollTo({ top: 0, behavior: 'smooth' });
        },

        cancelEdit() {
            this.editing = false;
            this.editItemId = '';
            this.label = '';
            this.url = '';
            this.linkType = 'custom';
            this.linkId = '';
            this.target = '_self';
            this.parentId = '';
        }
    };
}
</script>
}
