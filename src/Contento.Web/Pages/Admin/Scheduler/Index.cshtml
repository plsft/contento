@page "/admin/scheduler"
@model Contento.Web.Pages.Admin.Scheduler.IndexModel
@{
    ViewData["Title"] = "Task Scheduler";
}

<div class="max-w-7xl mx-auto" x-data="schedulerPage()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Task Scheduler</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">Manage automated cron tasks for your site</p>
        </div>
        <button @@click="showCreate = !showCreate" class="btn btn-primary btn-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
            New Task
        </button>
    </div>

    <!-- Create Form -->
    <div x-show="showCreate" x-cloak x-transition class="card mb-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold" style="color: var(--color-ink);">New Scheduled Task</h3>
            <button @@click="showCreate = false" class="p-1 rounded hover:bg-stone-100" style="color: var(--color-ash);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <form method="post" asp-page-handler="Create">
            <div class="space-y-4">
                <div>
                    <label class="form-label">Name</label>
                    <input type="text" name="Name" class="form-input" placeholder="e.g. Publish Scheduled Posts" required />
                </div>
                <div>
                    <label class="form-label">Task Type</label>
                    <select name="TaskType" x-model="taskType" class="form-input" required>
                        <option value="">Select a task type...</option>
                        <option value="publish_scheduled">Publish Scheduled</option>
                        <option value="cleanup_trash">Cleanup Trash</option>
                        <option value="cleanup_spam">Cleanup Spam</option>
                        <option value="expire_memberships">Expire Memberships</option>
                        <option value="generate_sitemap">Generate Sitemap</option>
                        <option value="send_newsletter">Send Newsletter</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Cron Expression</label>
                    <input type="text" name="CronExpression" x-model="cronExpression" class="form-input font-mono" placeholder="* * * * *" required />
                    <div class="flex flex-wrap gap-2 mt-2">
                        <button type="button" @@click="cronExpression = '* * * * *'" class="btn btn-ghost btn-sm text-xs">Every minute</button>
                        <button type="button" @@click="cronExpression = '*/5 * * * *'" class="btn btn-ghost btn-sm text-xs">Every 5 min</button>
                        <button type="button" @@click="cronExpression = '0 * * * *'" class="btn btn-ghost btn-sm text-xs">Hourly</button>
                        <button type="button" @@click="cronExpression = '0 3 * * *'" class="btn btn-ghost btn-sm text-xs">Daily 3AM</button>
                        <button type="button" @@click="cronExpression = '0 4 * * 0'" class="btn btn-ghost btn-sm text-xs">Weekly Sun 4AM</button>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <button type="submit" class="btn btn-primary btn-sm">Create Task</button>
                    <button type="button" @@click="showCreate = false" class="btn btn-ghost btn-sm">Cancel</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Tasks Table -->
    @if (Model.Tasks.Any())
    {
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Cron</th>
                        <th>Last Run</th>
                        <th>Status</th>
                        <th>Next Run</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        <tr>
                            <td>
                                <div class="flex items-center gap-2">
                                    <span class="font-medium" style="color: var(--color-ink);">@task.Name</span>
                                    @if (!task.IsEnabled)
                                    {
                                        <span class="badge badge-neutral">Disabled</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-info">@task.TaskType</span>
                            </td>
                            <td>
                                <span class="text-xs font-mono" style="color: var(--color-ash);">@task.CronExpression</span>
                            </td>
                            <td style="white-space: nowrap;">
                                @if (task.LastRunAt.HasValue)
                                {
                                    <span class="text-sm" style="color: var(--color-ash);">@task.LastRunAt.Value.ToString("MMM d, yyyy HH:mm")</span>
                                }
                                else
                                {
                                    <span class="text-sm" style="color: var(--color-cloud);">Never</span>
                                }
                            </td>
                            <td>
                                @if (task.LastResult == "success")
                                {
                                    <span class="badge badge-success">Success</span>
                                }
                                else if (task.LastResult == "failed")
                                {
                                    <span class="badge badge-error">Failed</span>
                                }
                                else if (task.LastResult == "running")
                                {
                                    <span class="badge badge-warning">Running</span>
                                }
                                else
                                {
                                    <span class="text-sm" style="color: var(--color-cloud);">--</span>
                                }
                            </td>
                            <td style="white-space: nowrap;">
                                @if (task.NextRunAt.HasValue)
                                {
                                    <span class="text-sm" style="color: var(--color-ash);">@task.NextRunAt.Value.ToString("MMM d, yyyy HH:mm")</span>
                                }
                                else
                                {
                                    <span class="text-sm" style="color: var(--color-cloud);">--</span>
                                }
                            </td>
                            <td>
                                <div class="flex items-center gap-1">
                                    <form method="post" asp-page-handler="RunNow" class="inline">
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-indigo);" title="Run Now">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                            </svg>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" class="inline">
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);" title="Delete">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="card text-center py-12">
            <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p style="color: var(--color-cloud);">No scheduled tasks.</p>
            <p class="text-sm mt-2" style="color: var(--color-ash);">Create a task to automate recurring operations.</p>
        </div>
    }
</div>

@section Scripts {
<script>
function schedulerPage() {
    return {
        showCreate: false,
        taskType: '',
        cronExpression: ''
    };
}
</script>
}
