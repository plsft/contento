@page "/admin/settings/ai"
@model Contento.Web.Pages.Admin.Settings.AiModel
@{
    ViewData["Title"] = "AI Settings";
}

<div class="max-w-3xl mx-auto" x-data="aiSettings()">
    <!-- Header -->
    <div class="mb-6">
        <h2 class="text-xl font-semibold" style="color: var(--color-ink);">AI Settings</h2>
        <p class="text-sm mt-1" style="color: var(--color-ash);">Configure your AI provider for writing assistance and content generation</p>
    </div>

    <!-- Success Message -->
    @if (Model.SaveSuccess)
    {
        <div class="alert alert-success mb-6">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-sm font-medium">AI settings saved successfully.</span>
        </div>
    }

    <!-- Settings Form -->
    <form method="post">
        <!-- Provider -->
        <div class="card mb-6">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Provider</h3>
            <div class="space-y-4">
                <div>
                    <label class="form-label">AI Provider</label>
                    <select asp-for="Provider" class="form-input" x-model="provider" @@change="updateModel()">
                        <option value="openai">OpenAI</option>
                        <option value="anthropic">Anthropic</option>
                        <option value="google">Google</option>
                    </select>
                    <p class="text-xs mt-1" style="color: var(--color-cloud);">Select your AI provider. You'll need an API key from this provider.</p>
                </div>
                <div>
                    <label class="form-label">Model</label>
                    <input type="text" asp-for="Model" class="form-input" x-model="model" placeholder="e.g., openai/gpt-4o" />
                    <p class="text-xs mt-1" style="color: var(--color-cloud);">Format: provider/model (e.g., openai/gpt-4o, anthropic/claude-sonnet-4, google/gemini-2.0-flash)</p>
                </div>
            </div>
        </div>

        <!-- API Key -->
        <div class="card mb-6">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">API Key</h3>
            <div class="space-y-4">
                <div>
                    <label class="form-label">API Key</label>
                    <input type="password" asp-for="ApiKey" class="form-input" placeholder="Enter your API key" autocomplete="off" />
                    @if (!string.IsNullOrEmpty(Model.MaskedKey))
                    {
                        <p class="text-xs mt-1" style="color: var(--color-ash);">Current key: @Model.MaskedKey — leave blank to keep existing key</p>
                    }
                    <p class="text-xs mt-1" style="color: var(--color-cloud);">Your API key is stored encrypted in the database and never exposed to the browser.</p>
                </div>
                <div>
                    <label class="flex items-center gap-3">
                        <input type="checkbox" asp-for="Enabled" class="rounded" style="accent-color: var(--color-indigo);" />
                        <span class="text-sm" style="color: var(--color-stone);">Enable AI features</span>
                    </label>
                    <p class="text-xs mt-1 ml-8" style="color: var(--color-cloud);">When enabled, AI writing assistant and generation features will be available throughout the admin.</p>
                </div>
            </div>
        </div>

        <!-- Test Connection -->
        <div class="card mb-6">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Test Connection</h3>
            <p class="text-sm mb-3" style="color: var(--color-ash);">Save your settings first, then test the connection to verify your API key works.</p>
            <button type="button" @@click="testConnection()" class="btn btn-secondary btn-sm" :disabled="testing">
                <template x-if="!testing">
                    <span>Test Connection</span>
                </template>
                <template x-if="testing">
                    <span>Testing...</span>
                </template>
            </button>
            <div x-show="testResult" x-cloak class="mt-3 text-sm px-3 py-2 rounded"
                 :class="testSuccess ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200'"
                 x-text="testResult"></div>
        </div>

        <!-- Save -->
        <div class="flex justify-end">
            <button type="submit" class="btn btn-primary">Save AI Settings</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
function aiSettings() {
    return {
        provider: '@Model.Provider',
        model: '@Model.Model',
        testing: false,
        testResult: '',
        testSuccess: false,

        updateModel() {
            const defaults = {
                openai: 'openai/gpt-4o-mini',
                anthropic: 'anthropic/claude-sonnet-4',
                google: 'google/gemini-2.0-flash'
            };
            this.model = defaults[this.provider] || this.provider + '/';
            // Update the hidden input
            document.querySelector('[name="Model"]').value = this.model;
        },

        async testConnection() {
            this.testing = true;
            this.testResult = '';
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('/api/v1/ai/complete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': token || ''
                    },
                    body: JSON.stringify({
                        systemPrompt: 'Respond with exactly: Connection successful.',
                        userPrompt: 'Test'
                    })
                });
                const data = await response.json();
                if (response.ok) {
                    this.testSuccess = true;
                    this.testResult = 'Connection successful! Response: ' + (data.data?.text || '').substring(0, 100);
                } else {
                    this.testSuccess = false;
                    this.testResult = 'Connection failed: ' + (data.error?.message || 'Unknown error');
                }
            } catch (e) {
                this.testSuccess = false;
                this.testResult = 'Connection failed: ' + e.message;
            }
            this.testing = false;
        }
    };
}
</script>
}
