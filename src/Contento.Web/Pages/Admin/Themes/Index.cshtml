@page "/admin/themes"
@model Contento.Web.Pages.Admin.Themes.IndexModel
@{
    ViewData["Title"] = "Themes";
}

<div class="max-w-7xl mx-auto" x-data="aiThemeGenerator()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Themes</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">Visual themes for your public site</p>
        </div>
        <button @@click="showModal = true" class="btn btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
            </svg>
            Generate with AI
        </button>
    </div>

    <!-- AI Theme Generator Modal -->
    <div x-show="showModal" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4" style="background: rgba(0,0,0,0.4);">
        <div @@click.away="showModal = false" class="w-full max-w-lg rounded-xl shadow-2xl" style="background: var(--color-snow); border: 1px solid var(--color-mist);">
            <div class="p-6">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-base font-semibold flex items-center gap-2" style="color: var(--color-ink);">
                        <svg class="w-5 h-5" style="color: var(--color-indigo);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
                        </svg>
                        Generate Theme with AI
                    </h3>
                    <button @@click="showModal = false" class="p-1 rounded hover:bg-stone-100">
                        <svg class="w-5 h-5" style="color: var(--color-ash);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>

                <!-- Prompt input -->
                <div x-show="!preview">
                    <label class="form-label">Describe your theme</label>
                    <textarea x-model="prompt" rows="3" class="form-input" placeholder="e.g., A warm, cozy reading theme with earth tones and serif fonts..."></textarea>
                    <div class="flex gap-2 mt-4">
                        <button @@click="generate()" :disabled="loading || !prompt.trim()" class="btn btn-primary flex-1">
                            <span x-show="!loading">Generate</span>
                            <span x-show="loading" class="flex items-center gap-2">
                                <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                                Generating...
                            </span>
                        </button>
                    </div>
                    <div x-show="error" x-cloak class="mt-3 text-sm px-3 py-2 rounded bg-red-50 text-red-800 border border-red-200" x-text="error"></div>
                </div>

                <!-- Preview -->
                <div x-show="preview" x-cloak>
                    <div class="rounded-lg overflow-hidden mb-4" style="border: 1px solid var(--color-mist);">
                        <!-- Color swatches -->
                        <div class="flex h-20">
                            <template x-for="(color, key) in previewColors" :key="key">
                                <div class="flex-1 flex items-end justify-center pb-1" :style="'background-color:' + color">
                                    <span class="text-[10px] px-1 rounded" style="background: rgba(255,255,255,0.8); color: #333;" x-text="color"></span>
                                </div>
                            </template>
                        </div>
                    </div>
                    <div class="space-y-2 mb-4">
                        <p class="text-sm font-semibold" style="color: var(--color-ink);" x-text="preview.name"></p>
                        <p class="text-xs" style="color: var(--color-ash);" x-text="preview.description"></p>
                        <p class="text-xs" style="color: var(--color-cloud);" x-text="'Font: ' + (previewColors['--font-body'] || 'default')"></p>
                    </div>
                    <div class="flex gap-2">
                        <button @@click="saveTheme()" :disabled="saving" class="btn btn-primary flex-1">
                            <span x-show="!saving">Save Theme</span>
                            <span x-show="saving">Saving...</span>
                        </button>
                        <button @@click="preview = null; previewColors = {}" class="btn btn-secondary">Retry</button>
                        <button @@click="showModal = false; preview = null; prompt = ''; error = ''" class="btn btn-ghost">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Themes Grid -->
    @if (Model.Themes.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var theme in Model.Themes)
            {
                var colors = Model.GetPreviewColors(theme.CssVariables);
                <div class="card @(theme.IsActive ? "ring-2" : "")" style="@(theme.IsActive ? "border-color: var(--color-indigo); --tw-ring-color: var(--color-indigo);" : "")">
                    <!-- Color Preview -->
                    <div class="mb-4 rounded overflow-hidden" style="border: 1px solid var(--color-mist);">
                        @if (colors.Any())
                        {
                            <div class="flex h-16">
                                @foreach (var color in colors.Take(6))
                                {
                                    <div class="flex-1" style="background-color: @color.Value;" title="@color.Key: @color.Value"></div>
                                }
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(theme.ThumbnailUrl))
                        {
                            <img src="@theme.ThumbnailUrl" alt="@theme.Name preview" class="w-full h-16 object-cover" />
                        }
                        else
                        {
                            <div class="h-16 flex items-center justify-center" style="background-color: var(--color-paper);">
                                <svg class="w-6 h-6" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                                </svg>
                            </div>
                        }
                    </div>

                    <!-- Theme Info -->
                    <div class="flex items-start justify-between mb-2">
                        <div class="min-w-0">
                            <div class="flex items-center gap-2">
                                <h3 class="text-sm font-semibold truncate" style="color: var(--color-ink);">@theme.Name</h3>
                                @if (theme.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(theme.Description))
                            {
                                <p class="text-xs mt-1" style="color: var(--color-ash);">
                                    @(theme.Description.Length > 80 ? theme.Description[..80] + "..." : theme.Description)
                                </p>
                            }
                        </div>
                    </div>

                    <div class="flex items-center gap-3 text-xs" style="color: var(--color-cloud);">
                        @if (!string.IsNullOrEmpty(theme.Author))
                        {
                            <span>by @theme.Author</span>
                        }
                        @if (!string.IsNullOrEmpty(theme.Version))
                        {
                            <span>v@theme.Version</span>
                        }
                    </div>

                    <div class="flex items-center gap-2 mt-4 pt-4" style="border-top: 1px solid var(--color-mist);">
                        @if (!theme.IsActive)
                        {
                            <form method="post" asp-page-handler="Activate" class="inline">
                                <input type="hidden" name="id" value="@theme.Id" />
                                <button type="submit" class="btn btn-primary btn-sm">Activate</button>
                            </form>
                            <form method="post" asp-page-handler="Delete" class="inline ml-auto">
                                <input type="hidden" name="id" value="@theme.Id" />
                                <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">Delete</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-xs" style="color: var(--color-success);">Currently active</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card text-center py-16">
            <svg class="w-12 h-12 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
            <p style="color: var(--color-cloud);">No themes available.</p>
        </div>
    }
</div>

@section Scripts {
<script>
function aiThemeGenerator() {
    return {
        showModal: false,
        prompt: '',
        loading: false,
        saving: false,
        error: '',
        preview: null,
        previewColors: {},

        async generate() {
            this.loading = true;
            this.error = '';
            this.preview = null;
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('/api/v1/ai/generate-theme', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token || '' },
                    body: JSON.stringify({ prompt: this.prompt })
                });
                const data = await response.json();
                if (response.ok && data.data) {
                    this.preview = data.data;
                    // Parse CSS variables for color preview
                    try {
                        const vars = typeof data.data.cssVariables === 'string'
                            ? JSON.parse(data.data.cssVariables) : data.data.cssVariables;
                        this.previewColors = vars || {};
                    } catch { this.previewColors = {}; }
                } else {
                    this.error = data.error?.message || 'Failed to generate theme.';
                }
            } catch (e) {
                this.error = 'Request failed: ' + e.message;
            }
            this.loading = false;
        },

        async saveTheme() {
            if (!this.preview) return;
            this.saving = true;
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const cssVars = typeof this.preview.cssVariables === 'string'
                    ? this.preview.cssVariables : JSON.stringify(this.preview.cssVariables);
                const response = await fetch('/api/v1/themes', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token || '' },
                    body: JSON.stringify({
                        name: this.preview.name,
                        slug: this.preview.slug,
                        description: this.preview.description,
                        version: this.preview.version || '1.0.0',
                        author: this.preview.author || 'AI Generated',
                        cssVariables: cssVars
                    })
                });
                if (response.ok) {
                    window.location.reload();
                } else {
                    const data = await response.json();
                    this.error = data.error?.message || 'Failed to save theme.';
                }
            } catch (e) {
                this.error = 'Save failed: ' + e.message;
            }
            this.saving = false;
        }
    };
}
</script>
}
