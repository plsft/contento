@page "/admin/audit"
@model Contento.Web.Pages.Admin.Audit.IndexModel
@{
    ViewData["Title"] = "Audit Log";
}

<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Audit Log</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">@Model.TotalCount events recorded</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-6">
        <form method="get" class="flex flex-wrap items-end gap-4">
            <div>
                <label class="form-label">From</label>
                <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-input" />
            </div>
            <div>
                <label class="form-label">To</label>
                <input type="date" name="dateTo" value="@Model.DateTo" class="form-input" />
            </div>
            <div>
                <label class="form-label">Action</label>
                <input type="text" name="actionFilter" value="@Model.ActionFilter" class="form-input" placeholder="e.g. post.publish" />
            </div>
            <div class="flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">Filter</button>
                <a href="/admin/audit" class="btn btn-ghost btn-sm">Clear</a>
            </div>
        </form>
    </div>

    <!-- Audit Log Table -->
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>IP Address</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.AuditLogs.Any())
                {
                    @foreach (var log in Model.AuditLogs)
                    {
                        <tr>
                            <td style="white-space: nowrap;">
                                <span class="text-sm" style="color: var(--color-ash);">@log.CreatedAt.ToString("MMM d, yyyy HH:mm")</span>
                            </td>
                            <td>
                                <span class="text-sm" style="color: var(--color-stone);">
                                    @(log.UserId?.ToString("N")[..8] ?? "System")
                                </span>
                            </td>
                            <td>
                                <span class="badge @(log.Action switch {
                                    var a when a.Contains("create") || a.Contains("install") => "badge-success",
                                    var a when a.Contains("delete") || a.Contains("trash") || a.Contains("uninstall") => "badge-danger",
                                    var a when a.Contains("login") || a.Contains("logout") => "badge-info",
                                    var a when a.Contains("update") || a.Contains("publish") => "badge-warning",
                                    _ => "badge-neutral"
                                })">
                                    @IndexModel.FormatAction(log.Action)
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(log.EntityType))
                                {
                                    <div>
                                        <span class="text-sm" style="color: var(--color-stone);">@log.EntityType</span>
                                        @if (log.EntityId != null)
                                        {
                                            <span class="text-xs font-mono ml-1" style="color: var(--color-cloud);">@log.EntityId.Value.ToString("N")[..8]</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="color: var(--color-cloud);">--</span>
                                }
                            </td>
                            <td>
                                <span class="text-xs font-mono" style="color: var(--color-ash);">
                                    @(log.IpAddress ?? "--")
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-12">
                            <p style="color: var(--color-cloud);">No audit log entries found.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-center gap-2 mt-6">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <a href="/admin/audit?dateFrom=@Model.DateFrom&dateTo=@Model.DateTo&actionFilter=@Model.ActionFilter&page=@i"
                   class="px-3 py-1.5 text-sm rounded"
                   style="@(i == Model.Page ? "background-color: var(--color-indigo); color: white;" : "color: var(--color-stone);")">
                    @i
                </a>
            }
        </div>
    }
</div>
