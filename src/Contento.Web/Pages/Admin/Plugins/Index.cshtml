@page "/admin/plugins"
@model Contento.Web.Pages.Admin.Plugins.IndexModel
@{
    ViewData["Title"] = "Plugins";
}

<div class="max-w-5xl mx-auto" x-data="pluginInstaller()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Plugins</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">
                @Model.EnabledCount enabled of @Model.TotalCount installed
            </p>
        </div>
        <button @@click="showInstall = !showInstall" class="btn btn-primary btn-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
            Install Plugin
        </button>
    </div>

    <!-- Install Plugin Form -->
    <div x-show="showInstall" x-cloak x-transition class="card mb-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-base font-semibold" style="color: var(--color-ink);">Install Plugin</h3>
            <button @@click="showInstall = false" class="p-1 rounded hover:bg-stone-100" style="color: var(--color-ash);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <div class="space-y-4">
            <!-- Manifest JSON -->
            <div>
                <label class="form-label">Plugin Manifest (JSON)</label>
                <textarea x-model="manifestJson" rows="8" class="form-input font-mono text-xs"
                          placeholder='{
  "name": "My Plugin",
  "slug": "my-plugin",
  "version": "1.0.0",
  "author": "Your Name",
  "description": "What this plugin does",
  "hooks": ["post:render"]
}'></textarea>
            </div>

            <!-- Entry Point JS -->
            <div>
                <label class="form-label">Entry Point (JavaScript)</label>
                <textarea x-model="entryPointJs" rows="10" class="form-input font-mono text-xs"
                          placeholder="(function () {
    contento.on('post:render', function (context) {
        // Your plugin code here
    });
})();"></textarea>
            </div>

            <!-- Preview -->
            <div x-show="parsed" x-cloak class="p-4 rounded" style="background: var(--color-paper); border: 1px solid var(--color-mist);">
                <p class="text-xs font-semibold mb-2" style="color: var(--color-ash);">Preview</p>
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded flex items-center justify-center" style="background: var(--color-indigo-pale); color: var(--color-indigo);">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-sm font-semibold" style="color: var(--color-ink);" x-text="parsed?.name || 'Unnamed'"></p>
                        <p class="text-xs" style="color: var(--color-ash);" x-text="parsed?.description || ''"></p>
                        <p class="text-xs" style="color: var(--color-cloud);">
                            <span x-text="'by ' + (parsed?.author || 'Unknown')"></span> &middot;
                            <span x-text="'v' + (parsed?.version || '0.0.0')"></span> &middot;
                            <span x-text="(parsed?.hooks || []).join(', ')"></span>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Error -->
            <div x-show="error" x-cloak class="alert alert-error">
                <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                </svg>
                <span class="text-sm" x-text="error"></span>
            </div>

            <!-- Actions -->
            <div class="flex items-center gap-3">
                <button @@click="parseManifest()" class="btn btn-secondary btn-sm">Parse &amp; Preview</button>
                <button @@click="install()" :disabled="!parsed || installing" class="btn btn-primary btn-sm"
                        :class="{ 'opacity-50 cursor-not-allowed': !parsed || installing }">
                    <span x-show="!installing">Install</span>
                    <span x-show="installing" x-cloak>Installing...</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Plugins List -->
    @if (Model.Plugins.Any())
    {
        <div class="space-y-3">
            @foreach (var plugin in Model.Plugins)
            {
                <div class="card flex items-center gap-4">
                    <!-- Plugin icon -->
                    <div class="w-10 h-10 rounded flex items-center justify-center flex-shrink-0"
                         style="background-color: @(plugin.IsEnabled ? "var(--color-indigo-pale)" : "var(--color-paper)"); color: @(plugin.IsEnabled ? "var(--color-indigo)" : "var(--color-cloud)");">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                        </svg>
                    </div>

                    <!-- Plugin info -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2">
                            <h3 class="text-sm font-semibold" style="color: var(--color-ink);">@plugin.Name</h3>
                            <span class="badge @(plugin.IsEnabled ? "badge-success" : "badge-neutral")">
                                @(plugin.IsEnabled ? "Enabled" : "Disabled")
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(plugin.Description))
                        {
                            <p class="text-xs mt-0.5" style="color: var(--color-ash);">@plugin.Description</p>
                        }
                        <div class="flex items-center gap-3 mt-1">
                            @if (!string.IsNullOrEmpty(plugin.Author))
                            {
                                <span class="text-xs" style="color: var(--color-cloud);">by @plugin.Author</span>
                            }
                            <span class="text-xs" style="color: var(--color-cloud);">v@plugin.Version</span>
                        </div>
                    </div>

                    <!-- Toggle and actions -->
                    <div class="flex items-center gap-3 flex-shrink-0">
                        @if (plugin.IsEnabled)
                        {
                            <form method="post" asp-page-handler="Disable" class="inline">
                                <input type="hidden" name="id" value="@plugin.Id" />
                                <button type="submit" class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors"
                                        style="background-color: var(--color-indigo);" title="Disable">
                                    <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform translate-x-6"></span>
                                </button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Enable" class="inline">
                                <input type="hidden" name="id" value="@plugin.Id" />
                                <button type="submit" class="relative inline-flex h-6 w-11 items-center rounded-full transition-colors"
                                        style="background-color: var(--color-cloud);" title="Enable">
                                    <span class="inline-block h-4 w-4 transform rounded-full bg-white transition-transform translate-x-1"></span>
                                </button>
                            </form>
                        }
                        <form method="post" asp-page-handler="Uninstall" class="inline">
                            <input type="hidden" name="id" value="@plugin.Id" />
                            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);" title="Uninstall">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card text-center py-16" x-show="!showInstall">
            <svg class="w-12 h-12 mx-auto mb-3" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z"/>
            </svg>
            <p style="color: var(--color-cloud);">No plugins installed.</p>
            <button @@click="showInstall = true" class="btn btn-secondary btn-sm mt-4">Install your first plugin</button>
        </div>
    }
</div>

@section Scripts {
<script>
function pluginInstaller() {
    return {
        showInstall: false,
        manifestJson: '',
        entryPointJs: '',
        parsed: null,
        error: '',
        installing: false,

        parseManifest() {
            this.error = '';
            this.parsed = null;
            try {
                var manifest = JSON.parse(this.manifestJson);
                if (!manifest.name || !manifest.slug) {
                    this.error = 'Manifest must include "name" and "slug" fields.';
                    return;
                }
                if (!this.entryPointJs.trim()) {
                    this.error = 'Entry point JavaScript code is required.';
                    return;
                }
                this.parsed = manifest;
            } catch (e) {
                this.error = 'Invalid JSON: ' + e.message;
            }
        },

        async install() {
            if (!this.parsed || this.installing) return;
            this.installing = true;
            this.error = '';

            try {
                var response = await fetch('/api/v1/plugins/install', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name: this.parsed.name,
                        slug: this.parsed.slug,
                        version: this.parsed.version || '1.0.0',
                        author: this.parsed.author || '',
                        description: this.parsed.description || '',
                        entryPoint: this.entryPointJs,
                        permissions: this.parsed.hooks || [],
                        settings: '{}'
                    })
                });

                if (response.ok) {
                    window.location.reload();
                } else {
                    var data = await response.json();
                    this.error = data.error?.message || 'Installation failed.';
                }
            } catch (e) {
                this.error = 'Network error: ' + e.message;
            } finally {
                this.installing = false;
            }
        }
    };
}
</script>
}
