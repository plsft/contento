@page "/admin/plugins/{id}/settings"
@model Contento.Web.Pages.Admin.Plugins.SettingsModel
@{
    ViewData["Title"] = "Plugin Settings";
}

<div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="flex items-center gap-3 mb-6">
        <a href="/admin/plugins" class="p-2 rounded hover:bg-stone-100 transition-colors" style="color: var(--color-ash);">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
            </svg>
        </a>
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Plugin Settings</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">Configure plugin behavior</p>
        </div>
    </div>

    @if (Model.Plugin != null)
    {
        <!-- Plugin Info Card -->
        <div class="card mb-6">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded flex items-center justify-center flex-shrink-0"
                     style="background-color: @(Model.Plugin.IsEnabled ? "var(--color-indigo-pale)" : "var(--color-paper)"); color: @(Model.Plugin.IsEnabled ? "var(--color-indigo)" : "var(--color-cloud)");">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 14v6m-3-3h6M6 10h2a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2zm10 0h2a2 2 0 002-2V6a2 2 0 00-2-2h-2a2 2 0 00-2 2v2a2 2 0 002 2zM6 20h2a2 2 0 002-2v-2a2 2 0 00-2-2H6a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2">
                        <h3 class="text-base font-semibold" style="color: var(--color-ink);">@Model.Plugin.Name</h3>
                        <span class="badge @(Model.Plugin.IsEnabled ? "badge-success" : "badge-neutral")">
                            @(Model.Plugin.IsEnabled ? "Enabled" : "Disabled")
                        </span>
                    </div>
                    <div class="flex items-center gap-3 mt-1">
                        <span class="text-sm" style="color: var(--color-stone);">v@Model.Plugin.Version</span>
                        @if (!string.IsNullOrEmpty(Model.Plugin.Author))
                        {
                            <span class="text-sm" style="color: var(--color-ash);">by @Model.Plugin.Author</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Plugin.Description))
                    {
                        <p class="text-sm mt-2" style="color: var(--color-ash);">@Model.Plugin.Description</p>
                    }
                </div>
            </div>
        </div>

        <!-- Settings Editor Card -->
        <div class="card">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Settings JSON</h3>
            <form method="post" asp-route-id="@Model.Plugin.Id">
                <div>
                    <label class="form-label">Configuration</label>
                    <textarea name="SettingsJson" rows="16" class="form-input"
                              style="font-family: monospace; font-size: 0.8125rem; line-height: 1.6; tab-size: 2;">@Model.SettingsJson</textarea>
                    <p class="text-xs mt-2" style="color: var(--color-cloud);">
                        Edit the plugin settings as valid JSON. Invalid JSON will be rejected.
                    </p>
                </div>
                <div class="flex items-center gap-3 mt-4 pt-4" style="border-top: 1px solid var(--color-mist);">
                    <button type="submit" class="btn btn-primary btn-sm">Save Settings</button>
                    <a href="/admin/plugins" class="btn btn-ghost btn-sm">Cancel</a>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="card text-center py-16">
            <p style="color: var(--color-cloud);">Plugin not found.</p>
            <a href="/admin/plugins" class="btn btn-primary btn-sm mt-4">Back to Plugins</a>
        </div>
    }
</div>
