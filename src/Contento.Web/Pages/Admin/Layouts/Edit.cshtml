@page "/admin/layouts/{id}/edit"
@model Contento.Web.Pages.Admin.Layouts.EditModel
@{
    ViewData["Title"] = "Edit Layout";
}

<div class="max-w-7xl mx-auto" x-data="layoutEditor()">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <a href="/admin/layouts" class="p-2 rounded hover:bg-stone-100 transition-colors" style="color: var(--color-ash);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
            </a>
            <div>
                <h2 class="text-xl font-semibold" style="color: var(--color-ink);">@(Model.LayoutItem?.Name ?? "Layout Editor")</h2>
                <p class="text-sm mt-1" style="color: var(--color-ash);">Visual layout editor</p>
            </div>
        </div>
        <button x-on:click="showAddComponent = !showAddComponent" class="btn btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
            Add Component
        </button>
    </div>

    @if (Model.LayoutItem != null)
    {
        <!-- Add Component Form -->
        <div x-show="showAddComponent" x-cloak
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 -translate-y-2"
             x-transition:enter-end="opacity-100 translate-y-0"
             class="card mb-6">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Add Component</h3>
            <form method="post" asp-page-handler="AddComponent" asp-route-id="@Model.LayoutItem.Id">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div>
                        <label class="form-label">Region</label>
                        <select name="Region" class="form-input" required>
                            <option value="">Select region...</option>
                            <option value="header">Header</option>
                            <option value="menu">Menu</option>
                            <option value="meta">Meta</option>
                            <option value="left_nav">Left Nav</option>
                            <option value="body">Body</option>
                            <option value="right_nav">Right Nav</option>
                            <option value="footer">Footer</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Content Type</label>
                        <select name="ContentType" class="form-input" required>
                            <option value="">Select type...</option>
                            <option value="html">HTML</option>
                            <option value="markdown">Markdown</option>
                            <option value="widget">Widget</option>
                            <option value="menu">Menu</option>
                            <option value="search">Search</option>
                            <option value="categories">Categories</option>
                            <option value="tags">Tags</option>
                            <option value="recent_posts">Recent Posts</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Sort Order</label>
                        <input type="number" name="SortOrder" value="0" class="form-input" />
                    </div>
                    <div>
                        <label class="form-label">Content</label>
                        <input type="text" name="ComponentContent" class="form-input" placeholder="Optional content" />
                    </div>
                </div>
                <div class="flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-sm">Add</button>
                    <button type="button" x-on:click="showAddComponent = false" class="btn btn-ghost btn-sm">Cancel</button>
                </div>
            </form>
        </div>

        <!-- Grid-based Visual Layout Editor -->
        <div class="card mb-6">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Layout Preview</h3>
            <div class="rounded-lg overflow-hidden" style="border: 1px solid var(--color-mist);">
                <!-- Header Region (full width) -->
                <div class="p-3" style="background-color: var(--color-paper); border-bottom: 1px solid var(--color-mist);">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-ash);">Header</span>
                            <span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--color-indigo-pale); color: var(--color-indigo);">
                                @Model.Components.Count(c => c.Region == "header") components
                            </span>
                        </div>
                    </div>
                    @foreach (var comp in Model.Components.Where(c => c.Region == "header").OrderBy(c => c.SortOrder))
                    {
                        <div class="mt-2 p-2 rounded flex items-center justify-between" style="background-color: white; border: 1px solid var(--color-mist);">
                            <div class="flex items-center gap-2">
                                <span class="badge badge-neutral">@comp.ContentType</span>
                                <span class="text-xs" style="color: var(--color-ash);">Order: @comp.SortOrder</span>
                            </div>
                            <form method="post" asp-page-handler="DeleteComponent" asp-route-id="@Model.LayoutItem.Id" class="inline">
                                <input type="hidden" name="componentId" value="@comp.Id" />
                                <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    }
                </div>

                <!-- Menu Region (full width) -->
                <div class="p-3" style="background-color: var(--color-paper); border-bottom: 1px solid var(--color-mist);">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-ash);">Menu</span>
                        <span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--color-indigo-pale); color: var(--color-indigo);">
                            @Model.Components.Count(c => c.Region == "menu") components
                        </span>
                    </div>
                    @foreach (var comp in Model.Components.Where(c => c.Region == "menu").OrderBy(c => c.SortOrder))
                    {
                        <div class="mt-2 p-2 rounded flex items-center justify-between" style="background-color: white; border: 1px solid var(--color-mist);">
                            <div class="flex items-center gap-2">
                                <span class="badge badge-neutral">@comp.ContentType</span>
                                <span class="text-xs" style="color: var(--color-ash);">Order: @comp.SortOrder</span>
                            </div>
                            <form method="post" asp-page-handler="DeleteComponent" asp-route-id="@Model.LayoutItem.Id" class="inline">
                                <input type="hidden" name="componentId" value="@comp.Id" />
                                <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    }
                </div>

                <!-- Meta Region (full width) -->
                <div class="p-3" style="border-bottom: 1px solid var(--color-mist);">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-ash);">Meta</span>
                        <span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--color-indigo-pale); color: var(--color-indigo);">
                            @Model.Components.Count(c => c.Region == "meta") components
                        </span>
                    </div>
                    @foreach (var comp in Model.Components.Where(c => c.Region == "meta").OrderBy(c => c.SortOrder))
                    {
                        <div class="mt-2 p-2 rounded flex items-center justify-between" style="background-color: var(--color-paper); border: 1px solid var(--color-mist);">
                            <div class="flex items-center gap-2">
                                <span class="badge badge-neutral">@comp.ContentType</span>
                                <span class="text-xs" style="color: var(--color-ash);">Order: @comp.SortOrder</span>
                            </div>
                            <form method="post" asp-page-handler="DeleteComponent" asp-route-id="@Model.LayoutItem.Id" class="inline">
                                <input type="hidden" name="componentId" value="@comp.Id" />
                                <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    }
                </div>

                <!-- Three Column Area: Left Nav / Body / Right Nav -->
                <div style="display: grid; grid-template-columns: 2fr 8fr 2fr; min-height: 200px;">
                    <!-- Left Nav -->
                    <div class="p-3" style="border-right: 1px solid var(--color-mist); background-color: var(--color-paper);">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-ash);">Left Nav</span>
                            <span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--color-indigo-pale); color: var(--color-indigo);">
                                @Model.Components.Count(c => c.Region == "left_nav")
                            </span>
                        </div>
                        @foreach (var comp in Model.Components.Where(c => c.Region == "left_nav").OrderBy(c => c.SortOrder))
                        {
                            <div class="mb-2 p-2 rounded" style="background-color: white; border: 1px solid var(--color-mist);">
                                <div class="flex items-center justify-between">
                                    <span class="badge badge-neutral text-xs">@comp.ContentType</span>
                                    <form method="post" asp-page-handler="DeleteComponent" asp-route-id="@Model.LayoutItem.Id" class="inline">
                                        <input type="hidden" name="componentId" value="@comp.Id" />
                                        <button type="submit" class="text-xs" style="color: var(--color-danger);">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Body -->
                    <div class="p-3">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-ash);">Body</span>
                            <span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--color-indigo-pale); color: var(--color-indigo);">
                                @Model.Components.Count(c => c.Region == "body")
                            </span>
                        </div>
                        @if (!Model.Components.Any(c => c.Region == "body"))
                        {
                            <div class="flex items-center justify-center h-32 rounded" style="border: 2px dashed var(--color-mist);">
                                <p class="text-sm" style="color: var(--color-cloud);">Main content area</p>
                            </div>
                        }
                        @foreach (var comp in Model.Components.Where(c => c.Region == "body").OrderBy(c => c.SortOrder))
                        {
                            <div class="mb-2 p-3 rounded" style="background-color: var(--color-paper); border: 1px solid var(--color-mist);">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2">
                                        <span class="badge badge-neutral">@comp.ContentType</span>
                                        <span class="text-xs" style="color: var(--color-ash);">Order: @comp.SortOrder</span>
                                    </div>
                                    <form method="post" asp-page-handler="DeleteComponent" asp-route-id="@Model.LayoutItem.Id" class="inline">
                                        <input type="hidden" name="componentId" value="@comp.Id" />
                                        <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Right Nav -->
                    <div class="p-3" style="border-left: 1px solid var(--color-mist); background-color: var(--color-paper);">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-ash);">Right Nav</span>
                            <span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--color-indigo-pale); color: var(--color-indigo);">
                                @Model.Components.Count(c => c.Region == "right_nav")
                            </span>
                        </div>
                        @foreach (var comp in Model.Components.Where(c => c.Region == "right_nav").OrderBy(c => c.SortOrder))
                        {
                            <div class="mb-2 p-2 rounded" style="background-color: white; border: 1px solid var(--color-mist);">
                                <div class="flex items-center justify-between">
                                    <span class="badge badge-neutral text-xs">@comp.ContentType</span>
                                    <form method="post" asp-page-handler="DeleteComponent" asp-route-id="@Model.LayoutItem.Id" class="inline">
                                        <input type="hidden" name="componentId" value="@comp.Id" />
                                        <button type="submit" class="text-xs" style="color: var(--color-danger);">
                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Footer Region (full width) -->
                <div class="p-3" style="background-color: var(--color-paper); border-top: 1px solid var(--color-mist);">
                    <div class="flex items-center gap-2">
                        <span class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-ash);">Footer</span>
                        <span class="text-xs px-1.5 py-0.5 rounded" style="background-color: var(--color-indigo-pale); color: var(--color-indigo);">
                            @Model.Components.Count(c => c.Region == "footer") components
                        </span>
                    </div>
                    @foreach (var comp in Model.Components.Where(c => c.Region == "footer").OrderBy(c => c.SortOrder))
                    {
                        <div class="mt-2 p-2 rounded flex items-center justify-between" style="background-color: white; border: 1px solid var(--color-mist);">
                            <div class="flex items-center gap-2">
                                <span class="badge badge-neutral">@comp.ContentType</span>
                                <span class="text-xs" style="color: var(--color-ash);">Order: @comp.SortOrder</span>
                            </div>
                            <form method="post" asp-page-handler="DeleteComponent" asp-route-id="@Model.LayoutItem.Id" class="inline">
                                <input type="hidden" name="componentId" value="@comp.Id" />
                                <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Structure JSON Editor -->
        <div class="card">
            <h3 class="text-sm font-semibold mb-4" style="color: var(--color-ink);">Layout Structure (JSON)</h3>
            <form method="post" asp-page-handler="SaveStructure" asp-route-id="@Model.LayoutItem.Id">
                <div>
                    <label class="form-label">Structure JSONB</label>
                    <textarea name="StructureJson" rows="8" class="form-input" style="font-family: monospace; font-size: 0.8125rem;">@Model.LayoutItem.Structure</textarea>
                </div>
                <div class="flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-sm">Save Structure</button>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="card text-center py-16">
            <p style="color: var(--color-cloud);">Layout not found.</p>
            <a href="/admin/layouts" class="btn btn-primary btn-sm mt-4">Back to Layouts</a>
        </div>
    }
</div>

<script>
function layoutEditor() {
    return {
        showAddComponent: false
    };
}
</script>
