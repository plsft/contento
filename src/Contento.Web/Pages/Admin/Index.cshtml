@page "/admin"
@model Contento.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="max-w-7xl mx-auto">
    <!-- Greeting -->
    <div class="mb-8">
        <h2 class="text-2xl font-semibold" style="color: var(--color-ink); font-family: var(--font-serif);">
            Good @Model.TimeOfDay, @Model.UserName
        </h2>
        <p class="mt-1" style="color: var(--color-ash); font-size: 0.875rem;">
            @DateTime.Now.ToString("dddd, MMMM d, yyyy")
        </p>
    </div>

    <!-- New Post CTA -->
    <div class="text-center mb-10">
        <a href="/admin/posts/new" class="btn btn-primary btn-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/>
            </svg>
            New Post
        </a>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="card">
            <div class="stat-label">Published Posts</div>
            <div class="stat-value">@Model.PublishedCount</div>
        </div>
        <div class="card">
            <div class="stat-label">Drafts</div>
            <div class="stat-value">@Model.DraftCount</div>
        </div>
        <div class="card">
            <div class="stat-label">Views (30 days)</div>
            <div class="stat-value">@Model.ViewsThisMonth</div>
        </div>
        <div class="card">
            <div class="stat-label">Pending Comments</div>
            <div class="stat-value">@Model.PendingComments</div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Recent Drafts -->
        <div class="card">
            <h3 class="text-base font-semibold mb-4" style="color: var(--color-ink);">Recent Drafts</h3>
            @if (Model.RecentDrafts.Any())
            {
                <div class="space-y-3">
                    @foreach (var draft in Model.RecentDrafts)
                    {
                        <a href="/admin/posts/@draft.Id/edit" class="flex items-center justify-between py-2 px-3 rounded hover:bg-stone-50 transition-colors">
                            <div>
                                <p class="text-sm font-medium" style="color: var(--color-ink);">@draft.Title</p>
                                <p class="text-xs" style="color: var(--color-ash);">
                                    @draft.UpdatedAt.ToString("MMM d") · @(draft.WordCount ?? 0) words
                                </p>
                            </div>
                            <svg class="w-4 h-4" style="color: var(--color-cloud);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
                            </svg>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-center py-8" style="color: var(--color-cloud);">
                    No drafts yet. Start writing!
                </p>
            }
        </div>

        <!-- Pending Comments -->
        <div class="card">
            <h3 class="text-base font-semibold mb-4" style="color: var(--color-ink);">Pending Comments</h3>
            @if (Model.RecentComments.Any())
            {
                <div class="space-y-3">
                    @foreach (var comment in Model.RecentComments)
                    {
                        <div class="py-2 px-3 rounded" style="border: 1px solid var(--color-mist);">
                            <div class="flex items-center justify-between mb-1">
                                <span class="text-sm font-medium" style="color: var(--color-ink);">@comment.AuthorName</span>
                                <span class="text-xs" style="color: var(--color-ash);">@comment.CreatedAt.ToString("MMM d")</span>
                            </div>
                            <p class="text-sm" style="color: var(--color-stone);">
                                @(comment.BodyMarkdown.Length > 120 ? comment.BodyMarkdown[..120] + "..." : comment.BodyMarkdown)
                            </p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-sm text-center py-8" style="color: var(--color-cloud);">
                    No pending comments.
                </p>
            }
        </div>
    </div>
</div>
