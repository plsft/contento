@page "/admin/comments"
@model Contento.Web.Pages.Admin.Comments.IndexModel
@{
    ViewData["Title"] = "Comments";
}

<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-xl font-semibold" style="color: var(--color-ink);">Comments</h2>
            <p class="text-sm mt-1" style="color: var(--color-ash);">Moderate and manage comments across your site</p>
        </div>
    </div>

    <!-- Spam Stats -->
    @if (Model.SpamStats != null && Model.SpamStats.TotalChecked > 0)
    {
        <div class="flex items-center gap-4 mb-4 p-3 rounded-lg" style="background-color: var(--color-canvas);">
            <span class="text-xs font-medium" style="color: var(--color-ash);">Spam Protection:</span>
            <span class="text-xs" style="color: var(--color-success);">@Model.SpamStats.TotalApproved auto-approved</span>
            <span class="text-xs" style="color: var(--color-danger);">@Model.SpamStats.TotalBlocked blocked</span>
            <span class="text-xs" style="color: var(--color-ash);">@Model.SpamStats.TotalChecked total checked</span>
        </div>
    }

    <!-- Status Tabs -->
    <div class="flex gap-1 mb-6 border-b" style="border-color: var(--color-mist);">
        @foreach (var tab in new[] { ("pending", "Pending", Model.PendingCount), ("approved", "Approved", Model.ApprovedCount), ("spam", "Spam", Model.SpamCount), ("trash", "Trash", Model.TrashCount) })
        {
            <a href="/admin/comments?status=@tab.Item1"
               class="px-4 py-2.5 text-sm font-medium border-b-2 transition-colors flex items-center gap-2 @(Model.Status == tab.Item1 ? "border-[var(--color-indigo)] text-[var(--color-indigo)]" : "border-transparent text-[var(--color-ash)] hover:text-[var(--color-stone)]")">
                @tab.Item2
                @if (tab.Item3 > 0)
                {
                    <span class="badge @(Model.Status == tab.Item1 ? "badge-info" : "badge-neutral")">@tab.Item3</span>
                }
            </a>
        }
    </div>

    <!-- Comments Table -->
    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Author</th>
                    <th>Comment</th>
                    <th>In Response To</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Comments.Any())
                {
                    @foreach (var comment in Model.Comments)
                    {
                        <tr>
                            <td>
                                <div>
                                    <p class="text-sm font-medium" style="color: var(--color-ink);">@comment.AuthorName</p>
                                    @if (!string.IsNullOrEmpty(comment.AuthorEmail))
                                    {
                                        <p class="text-xs" style="color: var(--color-ash);">@comment.AuthorEmail</p>
                                    }
                                </div>
                            </td>
                            <td style="max-width: 320px;">
                                <p class="text-sm truncate" style="color: var(--color-stone);">
                                    @(comment.BodyMarkdown.Length > 120 ? comment.BodyMarkdown[..120] + "..." : comment.BodyMarkdown)
                                </p>
                            </td>
                            <td>
                                <span class="text-sm" style="color: var(--color-ash);">Post</span>
                            </td>
                            <td style="white-space: nowrap;">
                                <span class="text-sm" style="color: var(--color-ash);">@comment.CreatedAt.ToString("MMM d, yyyy")</span>
                            </td>
                            <td>
                                <div class="flex items-center gap-1">
                                    @if (Model.Status != "approved")
                                    {
                                        <form method="post" asp-page-handler="Approve" class="inline">
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-success);" title="Approve">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7"/>
                                                </svg>
                                            </button>
                                        </form>
                                    }
                                    @if (Model.Status != "spam")
                                    {
                                        <form method="post" asp-page-handler="Spam" class="inline">
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-warning);" title="Mark as Spam">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                                </svg>
                                            </button>
                                        </form>
                                    }
                                    @if (Model.Status == "trash")
                                    {
                                        <form method="post" asp-page-handler="Delete" class="inline">
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);" title="Delete Permanently">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-page-handler="Trash" class="inline">
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <button type="submit" class="btn btn-ghost btn-sm" style="color: var(--color-danger);" title="Move to Trash">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-12">
                            <p style="color: var(--color-cloud);">No @Model.Status comments.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="flex items-center justify-center gap-2 mt-6">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <a href="/admin/comments?status=@Model.Status&page=@i"
                   class="px-3 py-1.5 text-sm rounded"
                   style="@(i == Model.Page ? "background-color: var(--color-indigo); color: white;" : "color: var(--color-stone);")">
                    @i
                </a>
            }
        </div>
    }
</div>
