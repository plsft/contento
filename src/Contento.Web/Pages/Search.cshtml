@page "/search"
@model Contento.Web.Pages.SearchModel
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Q) ? "Search" : $"Search: {Model.Q}";
    Layout = "_PublicLayout";
    ViewData["SiteTitle"] = Model.SiteName;
    ViewData["SiteTagline"] = Model.SiteTagline;
    ViewData["CurrentPage"] = Model.CurrentPage;
    ViewData["TotalPages"] = Model.TotalPages;
    ViewData["PaginationUrl"] = "?q=" + Uri.EscapeDataString(Model.Q ?? "") + "&page={0}";
}

<div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-semibold mb-6" style="font-family: var(--font-serif); color: var(--color-ink);">Search</h1>

    <form method="get" class="mb-10">
        <div class="flex gap-2">
            <input type="text" name="q" value="@Model.Q"
                   placeholder="Search posts..."
                   class="flex-1 px-4 py-3 rounded-lg border text-sm"
                   style="border-color: var(--color-mist); background: var(--color-paper); color: var(--color-ink);"
                   autofocus />
            <button type="submit"
                    class="px-6 py-3 rounded-lg text-sm font-medium text-white"
                    style="background: var(--color-indigo);">
                Search
            </button>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.Q))
    {
        <p class="text-sm mb-6" style="color: var(--color-ash);">
            @Model.TotalResults result@(Model.TotalResults != 1 ? "s" : "") for "@Model.Q"
        </p>

        <div class="space-y-8">
            @foreach (var post in Model.Results)
            {
                <article>
                    @if (post.Tags != null && post.Tags.Length > 0)
                    {
                        <div class="flex gap-2 mb-1">
                            @foreach (var tag in post.Tags.Take(2))
                            {
                                <span class="text-xs font-medium uppercase tracking-wider" style="color: var(--color-indigo);">@tag</span>
                            }
                        </div>
                    }
                    <h2 class="text-xl font-semibold mb-1" style="font-family: var(--font-serif);">
                        <a href="/@post.Slug" class="hover:underline" style="color: var(--color-ink);">@post.Title</a>
                    </h2>
                    @if (!string.IsNullOrEmpty(post.Excerpt))
                    {
                        <p class="text-sm mb-2" style="color: var(--color-stone); line-height: 1.6;">@post.Excerpt</p>
                    }
                    <div class="flex items-center gap-3 text-xs" style="color: var(--color-ash);">
                        <time datetime="@post.PublishedAt?.ToString("yyyy-MM-dd")">
                            @post.PublishedAt?.ToString("MMMM d, yyyy")
                        </time>
                        <span>&middot;</span>
                        <span>@(post.ReadingTimeMinutes ?? 1) min read</span>
                    </div>
                </article>
            }
        </div>

    }

    <partial name="_Pagination" />
</div>
