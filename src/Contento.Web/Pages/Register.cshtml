@page "/register"
@model Contento.Web.Pages.RegisterModel
@{
    ViewData["Title"] = "Create your account";
    Layout = "_PublicLayout";
}

@section Head {
    <style>
        .register-container {
            max-width: 460px;
            margin: 2rem auto;
        }

        .register-card {
            background: var(--color-snow);
            border: 1px solid var(--color-mist);
            border-radius: 0.75rem;
            padding: 2.5rem;
        }

        .register-divider {
            height: 1px;
            background: var(--color-mist);
            margin: 1.5rem 0;
        }

        .password-toggle {
            position: absolute;
            right: 0.75rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: var(--color-ash);
            padding: 0.25rem;
        }

        .password-toggle:hover {
            color: var(--color-stone);
        }
    </style>
}

<div class="register-container">
    <!-- Header -->
    <div class="text-center mb-8">
        <div class="w-12 h-12 rounded-lg mx-auto flex items-center justify-center mb-4" style="background-color: var(--color-indigo);">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
            </svg>
        </div>
        <h1 class="text-xl font-semibold" style="color: var(--color-ink); font-family: var(--font-serif);">Create your account</h1>
        <p class="text-sm mt-1" style="color: var(--color-ash);">Join us to get started</p>
    </div>

    <!-- Register Card -->
    <div class="register-card">
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success mb-4" style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 0.5rem; padding: 1rem; display: flex; align-items: flex-start; gap: 0.5rem;">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="#16a34a" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-sm" style="color: #166534;">@Model.SuccessMessage</span>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-error mb-4">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-sm">@Model.ErrorMessage</span>
            </div>
        }

        @if (string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <form method="post" x-data="{ showPassword: false, showConfirm: false }">
                <div class="space-y-4">
                    <div>
                        <label class="form-label">Display Name</label>
                        <input type="text" asp-for="DisplayName" class="form-input" placeholder="Your name" required autofocus />
                    </div>

                    <div>
                        <label class="form-label">Email</label>
                        <input type="email" asp-for="Email" class="form-input" placeholder="you@example.com" required />
                    </div>

                    <div>
                        <label class="form-label">Password</label>
                        <div class="relative">
                            <input :type="showPassword ? 'text' : 'password'" asp-for="Password" class="form-input" placeholder="Create a password" required minlength="8" />
                            <button type="button" class="password-toggle" @@click="showPassword = !showPassword" tabindex="-1">
                                <template x-if="!showPassword">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </template>
                                <template x-if="showPassword">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                    </svg>
                                </template>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label class="form-label">Confirm Password</label>
                        <div class="relative">
                            <input :type="showConfirm ? 'text' : 'password'" asp-for="ConfirmPassword" class="form-input" placeholder="Confirm your password" required minlength="8" />
                            <button type="button" class="password-toggle" @@click="showConfirm = !showConfirm" tabindex="-1">
                                <template x-if="!showConfirm">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                    </svg>
                                </template>
                                <template x-if="showConfirm">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                    </svg>
                                </template>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="register-divider"></div>

                <button type="submit" class="btn btn-primary w-full">
                    Create Account
                </button>
            </form>
        }

        <p class="text-center text-sm mt-6" style="color: var(--color-ash);">
            Already have an account?
            <a href="/admin/login" style="color: var(--color-indigo); font-weight: 500;">Sign in</a>
        </p>
    </div>
</div>
