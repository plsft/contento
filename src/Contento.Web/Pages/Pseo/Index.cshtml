@page
@model Contento.Web.Pages.Pseo.PseoIndexModel
@{
    Layout = null;
    var project = Model.Project;
    var backLinkUrl = project.BackLinkUrl ?? "#";
    var backLinkText = project.BackLinkText ?? "Back to our site";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@System.Net.WebUtility.HtmlEncode(project.Name)</title>
    <meta name="robots" content="index, follow" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #1f2937; background: #ffffff; }
        .container { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }
        h1 { font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem; }
        .subtitle { color: #6b7280; margin-bottom: 2rem; }
        .page-list { list-style: none; }
        .page-list li { border-bottom: 1px solid #e5e7eb; }
        .page-list li:last-child { border-bottom: none; }
        .page-list a { display: block; padding: 1rem 0; text-decoration: none; color: #1f2937; transition: color 0.15s; }
        .page-list a:hover { color: #2563eb; }
        .page-list .page-title { font-size: 1.125rem; font-weight: 600; }
        .page-list .page-desc { font-size: 0.875rem; color: #6b7280; margin-top: 0.25rem; }
        .back-link { display: inline-block; margin-bottom: 1.5rem; color: #2563eb; text-decoration: none; font-size: 0.875rem; }
        .back-link:hover { text-decoration: underline; }
        .empty { text-align: center; padding: 3rem 0; color: #9ca3af; }
        header, footer { padding: 0; }
        @("@")media (max-width: 640px) {
            .container { padding: 1rem; }
            h1 { font-size: 1.5rem; }
        }
    </style>
    @if (!string.IsNullOrEmpty(project.CustomCss))
    {
        <style>@Html.Raw(project.CustomCss)</style>
    }
</head>
<body>
    @if (!string.IsNullOrEmpty(project.HeaderHtml))
    {
        <header>@Html.Raw(project.HeaderHtml)</header>
    }

    <div class="container">
        @if (!string.IsNullOrEmpty(project.BackLinkUrl))
        {
            <a href="@backLinkUrl" class="back-link">&larr; @System.Net.WebUtility.HtmlEncode(backLinkText)</a>
        }

        <h1>@System.Net.WebUtility.HtmlEncode(project.Name)</h1>

        @if (Model.Pages.Any())
        {
            <p class="subtitle">@Model.Pages.Count published pages</p>
            <ul class="page-list">
                @foreach (var pseoPage in Model.Pages)
                {
                    <li>
                        <a href="/@pseoPage.Slug">
                            <div class="page-title">@System.Net.WebUtility.HtmlEncode(pseoPage.Title)</div>
                            @if (!string.IsNullOrEmpty(pseoPage.MetaDescription))
                            {
                                <div class="page-desc">@System.Net.WebUtility.HtmlEncode(pseoPage.MetaDescription)</div>
                            }
                        </a>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="empty">
                <p>No pages have been published yet.</p>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(project.CtaHtml))
    {
        @Html.Raw(project.CtaHtml)
    }

    @if (!string.IsNullOrEmpty(project.FooterHtml))
    {
        <footer>@Html.Raw(project.FooterHtml)</footer>
    }
</body>
</html>
