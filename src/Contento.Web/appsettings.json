{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_CONNECTION_STRING}",
    "Redis": "${REDIS_CONNECTION_STRING}"
  },
  "Contento": {
    "SiteName": "Contento",
    "DefaultLocale": "en-US",
    "DefaultTimezone": "UTC",
    "MaxUploadSizeMb": 10,
    "AllowedUploadTypes": "image/jpeg,image/png,image/gif,image/webp,image/svg+xml,application/pdf,video/mp4",
    "StoragePath": "uploads"
  },
  "Admin": {
    "DefaultEmail": "admin@contento.local",
    "DefaultPassword": "${CONTENTO_ADMIN_PASSWORD}",
    "IpWhitelist": ""
  },
  "OAuth": {
    "DefaultRedirectUri": "/admin",
    "LoginPath": "/admin/login",
    "LogoutPath": "/oauth/logout",
    "Providers": {
      "google": {
        "ClientId": "${GOOGLE_CLIENT_ID}",
        "ClientSecret": "${GOOGLE_CLIENT_SECRET}"
      }
    }
  },
  "Smtp": {
    "Host": "${SMTP_HOST}",
    "Port": "587",
    "Username": "${SMTP_USERNAME}",
    "Password": "${SMTP_PASSWORD}",
    "From": "noreply@contento.local",
    "FromName": "Contento"
  },
  "Storage": {
    "Provider": "local",
    "LocalPath": "uploads",
    "S3": {
      "Endpoint": "${S3_ENDPOINT}",
      "AccessKey": "${S3_ACCESS_KEY}",
      "SecretKey": "${S3_SECRET_KEY}",
      "Bucket": "${S3_BUCKET}",
      "PublicUrl": "${S3_PUBLIC_URL}",
      "Region": "us-east-1"
    }
  },
  "Stripe": {
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "PublishableKey": "${STRIPE_PUBLISHABLE_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}",
    "PremiumPriceId": "${STRIPE_PREMIUM_PRICE_ID}"
  },
  "Pseo": {
    "CnameTarget": "pseo.contentocms.com",
    "DefaultBackLinkText": "Back to our site",
    "MaxPagesPerProject": 50000,
    "MaxConcurrentGenerations": 10,
    "DnsCheckIntervalMinutes": 5,
    "DnsTimeoutHours": 48
  },
  "GoogleSearchConsole": {
    "ClientId": "${GSC_CLIENT_ID}",
    "ClientSecret": "${GSC_CLIENT_SECRET}"
  },
  "AllowedHosts": "*"
}
